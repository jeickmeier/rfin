class AgencyCmoBuilder:
    def __init__(self, instrument_id: str) -> None: ...
    def deal_name(self, deal_name: str) -> "AgencyCmoBuilder": ...
    def agency(self, agency: AgencyProgram) -> "AgencyCmoBuilder": ...

"""Structured credit result types."""

from __future__ import annotations
from datetime import date
from typing import Any, Dict

class TrancheCashflows:
    @property
    def tranche_id(self) -> str: ...
    @property
    def final_balance(self) -> Any: ...
    @property
    def total_interest(self) -> Any: ...
    @property
    def total_principal(self) -> Any: ...
    @property
    def total_pik(self) -> Any: ...
    @property
    def total_writedown(self) -> Any: ...
    @property
    def cashflows(self) -> list[tuple[date, Any]]: ...
    @property
    def interest_flows(self) -> list[tuple[date, Any]]: ...
    @property
    def principal_flows(self) -> list[tuple[date, Any]]: ...
    @property
    def pik_flows(self) -> list[tuple[date, Any]]: ...
    @property
    def writedown_flows(self) -> list[tuple[date, Any]]: ...
    @property
    def detailed_flows(self) -> list[Any]: ...
    def to_dict(self) -> Any: ...
    def __repr__(self) -> str: ...

class TrancheValuation:
    @property
    def tranche_id(self) -> str: ...
    @property
    def pv(self) -> Any: ...
    @property
    def clean_price(self) -> float: ...
    @property
    def dirty_price(self) -> float: ...
    @property
    def accrued(self) -> Any: ...
    @property
    def wal(self) -> float: ...
    @property
    def modified_duration(self) -> float: ...
    @property
    def z_spread_bps(self) -> float: ...
    @property
    def cs01(self) -> float: ...
    @property
    def ytm(self) -> float: ...
    @property
    def metrics(self) -> Dict[str, float]: ...
    def to_dict(self) -> Any: ...
    def __repr__(self) -> str: ...

class PaymentRecord:
    @property
    def tier_id(self) -> str: ...
    @property
    def recipient_id(self) -> str: ...
    @property
    def priority(self) -> int: ...
    @property
    def recipient(self) -> str: ...
    @property
    def requested_amount(self) -> Any: ...
    @property
    def paid_amount(self) -> Any: ...
    @property
    def shortfall(self) -> Any: ...
    @property
    def diverted(self) -> bool: ...
    def to_dict(self) -> Any: ...
    def __repr__(self) -> str: ...

class WaterfallDistribution:
    @property
    def payment_date(self) -> date: ...
    @property
    def total_available(self) -> Any: ...
    @property
    def diverted_cash(self) -> Any: ...
    @property
    def remaining_cash(self) -> Any: ...
    @property
    def had_diversions(self) -> bool: ...
    @property
    def diversion_reason(self) -> str | None: ...
    @property
    def tier_allocations(self) -> list[tuple[str, Any]]: ...
    @property
    def payment_records(self) -> list[PaymentRecord]: ...
    @property
    def coverage_tests(self) -> list[tuple[str, float, bool]]: ...
    def to_dict(self) -> Any: ...
    def __repr__(self) -> str: ...

class TestResult:
    @property
    def test_id(self) -> str: ...
    @property
    def current_ratio(self) -> float: ...
    @property
    def is_passing(self) -> bool: ...
    @property
    def cure_amount(self) -> Any | None: ...
    def to_dict(self) -> Any: ...
    def __repr__(self) -> str: ...

__all__ = [
    "TrancheCashflows",
    "TrancheValuation",
    "PaymentRecord",
    "WaterfallDistribution",
    "TestResult",
]

    def to_dict(self) -> Any: ...
    @classmethod
    def from_dict(cls, data: Any) -> "PaymentCalculation": ...
    def __repr__(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class CoverageTestType(IntEnum):
    OC = 0
    IC = 1

class RoundingConvention(IntEnum):

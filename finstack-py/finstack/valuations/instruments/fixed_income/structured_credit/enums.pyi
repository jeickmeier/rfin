    @classmethod
    def fixed_amount(cls, amount: float, currency: str) -> "PaymentCalculation": ...
    @classmethod
    def percentage_of_collateral(cls, rate: float, annualized: bool = True) -> "PaymentCalculation": ...
    @classmethod
    def tranche_interest(cls, tranche_id: str) -> "PaymentCalculation": ...
    @classmethod
    def tranche_principal(cls, tranche_id: str, target_balance: float | None = None) -> "PaymentCalculation": ...
    @classmethod

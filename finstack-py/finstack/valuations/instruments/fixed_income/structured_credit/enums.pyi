"""Structured credit enum types."""

from __future__ import annotations
from datetime import date
from typing import Any
from enum import IntEnum

class AssetType:
    PRIME_CREDIT_CARD: "AssetType"
    SUBPRIME_CREDIT_CARD: "AssetType"
    SUPER_PRIME_CREDIT_CARD: "AssetType"
    COMMERCIAL_CREDIT_CARD: "AssetType"
    FEDERAL_STUDENT_LOAN: "AssetType"
    PRIVATE_STUDENT_LOAN: "AssetType"
    FFELP_STUDENT_LOAN: "AssetType"
    CONSOLIDATION_STUDENT_LOAN: "AssetType"
    @classmethod
    def first_lien_loan(cls, industry: str | None = None) -> "AssetType": ...
    @classmethod
    def second_lien_loan(cls, industry: str | None = None) -> "AssetType": ...
    @classmethod
    def revolver_loan(cls, industry: str | None = None) -> "AssetType": ...
    @classmethod
    def bridge_loan(cls, industry: str | None = None) -> "AssetType": ...
    @classmethod
    def mezzanine_loan(cls, industry: str | None = None) -> "AssetType": ...
    @classmethod
    def high_yield_bond(cls, industry: str | None = None) -> "AssetType": ...
    @classmethod
    def investment_grade_bond(cls, industry: str | None = None) -> "AssetType": ...
    @classmethod
    def distressed_bond(cls, industry: str | None = None) -> "AssetType": ...
    @classmethod
    def emerging_markets_bond(cls, industry: str | None = None) -> "AssetType": ...
    @classmethod
    def single_family_mortgage(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def multifamily_mortgage(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def commercial_mortgage(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def industrial_mortgage(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def retail_mortgage(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def office_mortgage(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def hotel_mortgage(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def other_mortgage(cls, property_type: str, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def new_auto_loan(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def used_auto_loan(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def lease_auto_loan(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def fleet_auto_loan(cls, ltv: float | None = None) -> "AssetType": ...
    @classmethod
    def equipment(cls, equipment_type: str) -> "AssetType": ...
    @classmethod
    def generic(cls, description: str, asset_class: str) -> "AssetType": ...
    def is_amortizing(self) -> bool: ...
    def to_dict(self) -> Any: ...
    @classmethod
    def from_dict(cls, data: Any) -> "AssetType": ...
    def __repr__(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class PaymentMode:
    @classmethod
    def pro_rata(cls) -> "PaymentMode": ...
    @classmethod
    def sequential(cls, triggered_by: str, trigger_date: date) -> "PaymentMode": ...
    @classmethod
    def hybrid(cls, description: str) -> "PaymentMode": ...
    def to_dict(self) -> Any: ...
    @classmethod
    def from_dict(cls, data: Any) -> "PaymentMode": ...
    def __repr__(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...

class TriggerConsequence:
    DIVERT_CASH_FLOW: "TriggerConsequence"
    TRAP_EXCESS_SPREAD: "TriggerConsequence"
    ACCELERATE_AMORTIZATION: "TriggerConsequence"
    STOP_REINVESTMENT: "TriggerConsequence"

class TrancheBehaviorType(IntEnum):
    Standard = 0

class TrancheCoupon:
    @classmethod
    def fixed(cls, rate: float) -> "TrancheCoupon": ...
    @classmethod
    def floating(cls, spec: Any) -> "TrancheCoupon": ...
    def current_rate(self, date: date) -> float: ...
    def to_dict(self) -> Any: ...
    @classmethod
    def from_dict(cls, data: Any) -> "TrancheCoupon": ...
    def __repr__(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...


    @classmethod
    def cmbs_standard(cls, dates: DealDates, currency: str = "USD") -> "DealConfig": ...
    @property
    def dates(self) -> DealDates: ...
    @property
    def fees(self) -> DealFees: ...
    @property
    def coverage_tests(self) -> CoverageTestConfig: ...
    @property
    def default_assumptions(self) -> DefaultAssumptions: ...
    def to_dict(self) -> Any: ...
    @classmethod
    def from_dict(cls, data: Any) -> "DealConfig": ...
    def __repr__(self) -> str: ...

__all__ = [
    "DefaultAssumptions",
    "DealFees",
    "DealDates",

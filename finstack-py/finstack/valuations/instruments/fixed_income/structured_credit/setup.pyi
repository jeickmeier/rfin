class DealConfig:
    @classmethod
    def standard(cls, deal_type_str: str, dates: DealDates, currency: str = "USD") -> "DealConfig": ...
    @classmethod
    def clo_standard(cls, dates: DealDates, currency: str = "USD") -> "DealConfig": ...
    @classmethod
    def rmbs_standard(cls, dates: DealDates, currency: str = "USD") -> "DealConfig": ...
    @classmethod

"""Structured credit deal configuration types."""

from __future__ import annotations
from datetime import date
from typing import Any, Dict

class DefaultAssumptions:
    def __init__(
        self,
        base_cdr_annual: float | None = None,
        base_recovery_rate: float | None = None,
        base_cpr_annual: float | None = None,
        psa_speed: float | None = None,
        sda_speed: float | None = None,
        abs_speed_monthly: float | None = None,
    ) -> None: ...
    @classmethod
    def clo_standard(cls) -> "DefaultAssumptions": ...
    @classmethod
    def rmbs_standard(cls) -> "DefaultAssumptions": ...
    @classmethod
    def abs_auto_standard(cls) -> "DefaultAssumptions": ...
    @classmethod
    def cmbs_standard(cls) -> "DefaultAssumptions": ...
    @property
    def base_cdr_annual(self) -> float: ...
    @property
    def base_recovery_rate(self) -> float: ...
    @property
    def base_cpr_annual(self) -> float: ...
    @property
    def psa_speed(self) -> float | None: ...
    @property
    def sda_speed(self) -> float | None: ...
    @property
    def abs_speed_monthly(self) -> float | None: ...
    @property
    def cpr_by_asset_type(self) -> Dict[str, float]: ...
    @property
    def cdr_by_asset_type(self) -> Dict[str, float]: ...
    @property
    def recovery_by_asset_type(self) -> Dict[str, float]: ...
    def to_dict(self) -> Any: ...
    @classmethod
    def from_dict(cls, data: Any) -> "DefaultAssumptions": ...
    def __repr__(self) -> str: ...

class DealFees:
    def __init__(
        self,
        trustee_fee_annual: Any,
        senior_mgmt_fee_bps: float = 0.0,
        subordinated_mgmt_fee_bps: float = 0.0,
        servicing_fee_bps: float = 0.0,
        master_servicer_fee_bps: float | None = None,
        special_servicer_fee_bps: float | None = None,
    ) -> None: ...
    @classmethod
    def clo_standard(cls, currency: str = "USD") -> "DealFees": ...
    @classmethod
    def abs_standard(cls, currency: str = "USD") -> "DealFees": ...
    @classmethod
    def cmbs_standard(cls, currency: str = "USD") -> "DealFees": ...
    @classmethod
    def rmbs_standard(cls, currency: str = "USD") -> "DealFees": ...
    @property
    def trustee_fee_annual(self) -> Any: ...
    @property
    def senior_mgmt_fee_bps(self) -> float: ...
    @property
    def subordinated_mgmt_fee_bps(self) -> float: ...
    @property
    def servicing_fee_bps(self) -> float: ...
    @property
    def master_servicer_fee_bps(self) -> float | None: ...
    @property
    def special_servicer_fee_bps(self) -> float | None: ...
    def to_dict(self) -> Any: ...
    @classmethod
    def from_dict(cls, data: Any) -> "DealFees": ...
    def __repr__(self) -> str: ...

class DealDates:
    def __init__(
        self,
        closing_date: date,
        first_payment_date: date,
        maturity: date,
        frequency: Any | None = None,
    ) -> None: ...
    def with_reinvestment_end(self, date: date) -> "DealDates": ...
    @property
    def closing_date(self) -> date: ...
    @property
    def first_payment_date(self) -> date: ...
    @property
    def reinvestment_end_date(self) -> date | None: ...
    @property
    def maturity(self) -> date: ...
    @property
    def frequency(self) -> str: ...
    def to_dict(self) -> Any: ...
    @classmethod
    def from_dict(cls, data: Any) -> "DealDates": ...
    def __repr__(self) -> str: ...


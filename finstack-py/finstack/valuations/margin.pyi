class RepoMarginSpec:
    """GMRA 2011 compliant repo margin specification."""

    def __init__(
        self,
        margin_type: RepoMarginType | str,
        margin_ratio: float,
        margin_call_threshold: float,
        *,
        call_frequency: MarginTenor | str | None = ...,
        settlement_lag: int = ...,
        pays_margin_interest: bool = ...,
        margin_interest_rate: float | None = ...,
        substitution_allowed: bool = ...,
    ) -> None: ...
    @staticmethod
    def none() -> RepoMarginSpec: ...
    @staticmethod
    def mark_to_market(margin_ratio: float, threshold: float) -> RepoMarginSpec: ...
    @staticmethod
    def triparty(margin_ratio: float) -> RepoMarginSpec: ...
    @property
    def margin_type(self) -> RepoMarginType: ...
    @property
    def margin_ratio(self) -> float: ...
    @property
    def margin_call_threshold(self) -> float: ...
    @property
    def call_frequency(self) -> MarginTenor: ...
    @property
    def settlement_lag(self) -> int: ...
    @property
    def pays_margin_interest(self) -> bool: ...
    @property
    def margin_interest_rate(self) -> float | None: ...
    @property
    def substitution_allowed(self) -> bool: ...
    def has_margining(self) -> bool: ...
    def required_collateral(self, cash_amount: float) -> float: ...
    def call_trigger_value(self, cash_amount: float) -> float: ...
    def requires_margin_call(self, cash_amount: float, current_collateral: float) -> bool: ...
    def margin_deficit(self, cash_amount: float, current_collateral: float) -> float: ...
    def excess_collateral(self, cash_amount: float, current_collateral: float) -> float: ...

class VmCalculator:
    """Variation margin calculator following ISDA CSA rules."""

    def __init__(self, csa: CsaSpec) -> None: ...
    def calculate(
        self,
        exposure: Money,
        posted_collateral: Money,
        as_of: datetime.date,
    ) -> VmResult: ...
    def generate_margin_calls(
        self,
        exposures: list[tuple[datetime.date, Money]],
        initial_collateral: Money,
    ) -> list[MarginCall]: ...
    def margin_call_dates(
        self,
        start: datetime.date,
        end: datetime.date,
    ) -> list[datetime.date]: ...

class SimmVersion:
    """SIMM version identifier."""

    V2_5: SimmVersion
    V2_6: SimmVersion

    @property
    def name(self) -> str: ...

class SimmCalculator:
    """ISDA SIMM calculator for sensitivity-based IM."""

    def __init__(self, version: SimmVersion | None = ...) -> None: ...
    def calculate_from_sensitivities(
        self,
        sensitivities: SimmSensitivities,
        currency: Currency | str,
    ) -> tuple[float, dict[str, Money]]: ...


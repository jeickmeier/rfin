class SimmSensitivities:
    """SIMM sensitivity inputs organized by risk class."""

    def __init__(self, base_currency: Currency | str) -> None: ...
    @property
    def base_currency(self) -> Currency: ...
    def add_ir_delta(self, currency: Currency | str, tenor: str, delta: float) -> None: ...
    def add_ir_vega(self, currency: Currency | str, tenor: str, vega: float) -> None: ...
    def add_credit_delta(self, name: str, qualifying: bool, tenor: str, delta: float) -> None: ...
    def add_equity_delta(self, underlier: str, delta: float) -> None: ...
    def add_equity_vega(self, underlier: str, vega: float) -> None: ...
    def add_fx_delta(self, currency: Currency | str, delta: float) -> None: ...
    def is_empty(self) -> bool: ...
    def total_ir_delta(self) -> float: ...
    def total_credit_delta(self) -> float: ...
    def total_equity_delta(self) -> float: ...
    def merge(self, other: SimmSensitivities) -> None: ...

class OtcMarginSpec:
    """OTC derivative margin specification (ISDA CSA compliant)."""

    @staticmethod
    def bilateral_simm(csa: CsaSpec) -> OtcMarginSpec: ...
    @staticmethod
    def bilateral_schedule(csa: CsaSpec) -> OtcMarginSpec: ...
    @staticmethod

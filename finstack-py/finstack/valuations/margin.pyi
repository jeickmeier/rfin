    @staticmethod
    def usd_bilateral() -> OtcMarginSpec: ...
    @staticmethod
    def eur_bilateral() -> OtcMarginSpec: ...
    @staticmethod
    def lch_swapclear(currency: Currency | str) -> OtcMarginSpec: ...
    @staticmethod
    def cme_cleared(currency: Currency | str) -> OtcMarginSpec: ...
    @staticmethod
    def ice_clear_credit() -> OtcMarginSpec: ...
    @property

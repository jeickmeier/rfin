class InstrumentMarginResult:
    """Per-instrument margin calculation result."""

    @property
    def instrument_id(self) -> str: ...
    @property
    def as_of(self) -> datetime.date: ...
    @property
    def initial_margin(self) -> Money: ...
    @property
    def variation_margin(self) -> Money: ...
    @property

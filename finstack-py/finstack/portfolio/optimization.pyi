    def __repr__(self) -> str: ...

# ---------------------------------------------------------------------------
# Per-Position Metrics
# ---------------------------------------------------------------------------

class PerPositionMetric:
    """Source of a per-position scalar metric used in expressions.

    Factory methods specify where each position's metric value comes from --
    a standard ``MetricId``, a custom key, present value, a tag indicator, or
    a constant.

    Examples
    --------
    >>> from finstack.portfolio.optimization import PerPositionMetric
    >>> from finstack.valuations.metrics import MetricId
    >>> PerPositionMetric.metric(MetricId.DURATION_MOD)
    >>> PerPositionMetric.pv_base()
    >>> PerPositionMetric.constant(1.0)
    """

    @staticmethod
    def metric(metric_id: MetricId) -> PerPositionMetric:
        """Create from a standard :class:`MetricId`.

        Parameters
        ----------
        metric_id : MetricId
            The metric identifier (e.g., ``MetricId.DURATION_MOD``).

        Returns
        -------
        PerPositionMetric
            Metric source backed by a valuation metric.
        """
        ...

    @staticmethod
    def custom_key(key: str) -> PerPositionMetric:
        """Create from a custom string key.

        Parameters
        ----------
        key : str
            Arbitrary key looked up in position metadata.

        Returns
        -------
        PerPositionMetric
            Metric source backed by custom position data.
        """
        ...

    @staticmethod
    def pv_base() -> PerPositionMetric:
        """Use base-currency present value.

        Returns
        -------
        PerPositionMetric
            PV in the portfolio's base currency.
        """
        ...

    @staticmethod
    def pv_native() -> PerPositionMetric:
        """Use native-currency present value.

        Returns
        -------
        PerPositionMetric
            PV in the instrument's native currency.
        """
        ...

    @staticmethod
    def tag_equals(key: str, value: str) -> PerPositionMetric:
        """Tag-based 0/1 indicator (1 when ``tag[key] == value``).

        Parameters
        ----------
        key : str
            Tag key to check.
        value : str
            Tag value to match.

        Returns
        -------
        PerPositionMetric
            Binary indicator metric.
        """
        ...

    @staticmethod
    def constant(value: float) -> PerPositionMetric:
        """Constant scalar for all positions.

        Parameters
        ----------
        value : float
            Constant value applied uniformly.

        Returns
        -------
        PerPositionMetric
            Constant metric source.
        """
        ...

    def __repr__(self) -> str: ...

# ---------------------------------------------------------------------------
# Metric Expressions
# ---------------------------------------------------------------------------

class MetricExpr:
    """Portfolio-level scalar metric expressed in terms of position metrics and weights.

    Metric expressions are the building blocks of objectives and constraints.
    They define how per-position metrics are aggregated into a single
    portfolio-level scalar.

    Examples
    --------
    >>> from finstack.portfolio.optimization import MetricExpr, PerPositionMetric
    >>> from finstack.valuations.metrics import MetricId
    >>> MetricExpr.weighted_sum(PerPositionMetric.metric(MetricId.DURATION_MOD))
    >>> MetricExpr.value_weighted_average(PerPositionMetric.metric(MetricId.YTM))
    >>> MetricExpr.tag_exposure_share("rating", "HY")
    """

    @staticmethod
    def weighted_sum(metric: PerPositionMetric) -> MetricExpr:
        """Weighted sum: ``sum_i  w_i * m_i``.

        Parameters
        ----------
        metric : PerPositionMetric
            Per-position metric source.

        Returns
        -------
        MetricExpr
            Weighted-sum expression.
        """
        ...

    @staticmethod
    def value_weighted_average(metric: PerPositionMetric) -> MetricExpr:
        """Value-weighted average with implicit budget normalisation.

        Parameters
        ----------
        metric : PerPositionMetric
            Per-position metric source.

        Returns
        -------
        MetricExpr
            Value-weighted average expression.
        """
        ...

    @staticmethod
    def tag_exposure_share(tag_key: str, tag_value: str) -> MetricExpr:
        """Tag exposure share: ``sum_i  w_i * I[tag == value]``.

        Parameters
        ----------
        tag_key : str
            Tag key to filter on.
        tag_value : str
            Tag value that triggers the indicator.

        Returns
        -------
        MetricExpr
            Tag-exposure-share expression.
        """
        ...

    def __repr__(self) -> str: ...


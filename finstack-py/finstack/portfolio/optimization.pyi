"""Portfolio optimization DSL: objectives, constraints, trade universes, and solver.

This module exposes the full portfolio optimization framework including enum-like
configuration types, per-position metric sources, portfolio-level metric
expressions, constraint builders, trade universe definitions, and the
optimization problem itself.

Typical workflow::

    from finstack.portfolio.optimization import (
        PerPositionMetric,
        MetricExpr,
        Objective,
        Constraint,
        PortfolioOptimizationProblem,
    )
    from finstack.valuations.metrics import MetricId

    ytm = PerPositionMetric.metric(MetricId.YTM)
    obj = Objective.maximize(MetricExpr.value_weighted_average(ytm))
    problem = PortfolioOptimizationProblem.new(portfolio, obj)
    problem = problem.with_constraint(Constraint.tag_exposure_limit(None, "rating", "CCC", 0.10))
    result = problem.optimize(market_context)
"""

from __future__ import annotations

from typing import Any

from finstack.portfolio.portfolio import Portfolio
from finstack.portfolio.types import PositionUnit
from finstack.core.config import FinstackConfig
from finstack.core.market_data.context import MarketContext
from finstack.valuations.metrics import MetricId

# ---------------------------------------------------------------------------
# Enums
# ---------------------------------------------------------------------------

class WeightingScheme:
    """How optimization weights are defined.

    Attributes
    ----------
    VALUE_WEIGHT : WeightingScheme
        Weight ``w_i`` is the share of portfolio present value.
    NOTIONAL_WEIGHT : WeightingScheme
        Weight ``w_i`` is the share of notional exposure.
    UNIT_SCALING : WeightingScheme
        Weight ``w_i`` scales the current position size.

    Examples
    --------
    >>> from finstack.portfolio.optimization import WeightingScheme
    >>> WeightingScheme.VALUE_WEIGHT
    """

    VALUE_WEIGHT: WeightingScheme
    NOTIONAL_WEIGHT: WeightingScheme
    UNIT_SCALING: WeightingScheme

    def __repr__(self) -> str: ...

class MissingMetricPolicy:
    """Policy for handling positions that lack a required metric.

    Attributes
    ----------
    ZERO : MissingMetricPolicy
        Treat missing metric values as ``0.0`` (default).
    EXCLUDE : MissingMetricPolicy
        Exclude the position from the relevant constraint.
    STRICT : MissingMetricPolicy
        Raise an error when a metric is missing.

    Examples
    --------
    >>> from finstack.portfolio.optimization import MissingMetricPolicy
    >>> MissingMetricPolicy.ZERO
    """

    ZERO: MissingMetricPolicy
    EXCLUDE: MissingMetricPolicy
    STRICT: MissingMetricPolicy

    def __repr__(self) -> str: ...

class Inequality:
    """Inequality / equality operator used in constraints.

    Attributes
    ----------
    LE : Inequality
        Less-than or equal (``<=``).
    GE : Inequality
        Greater-than or equal (``>=``).
    EQ : Inequality
        Equality (``==``).

    Examples
    --------
    >>> from finstack.portfolio.optimization import Inequality
    >>> Inequality.LE
    """

    LE: Inequality
    GE: Inequality
    EQ: Inequality

    def __repr__(self) -> str: ...

class OptimizationStatus:
    """Status of a completed optimization run.

    The status is returned as part of :class:`OptimizationResult` and indicates
    whether the solver found an optimal, feasible, or infeasible solution.

    Examples
    --------
    >>> result.status.is_feasible()
    True
    """

    def is_feasible(self) -> bool:
        """Return ``True`` when the solution is feasible (optimal or sub-optimal).

        Returns
        -------
        bool
            Whether the solver found a feasible solution.
        """
        ...

    def __repr__(self) -> str: ...
    def __eq__(self, other: object) -> bool: ...

class TradeDirection:
    """Direction of a trade generated by the optimizer.

    Attributes
    ----------
    BUY : TradeDirection
        Position weight increased.
    SELL : TradeDirection
        Position weight decreased.
    HOLD : TradeDirection
        No change in position weight.

    Examples
    --------
    >>> from finstack.portfolio.optimization import TradeDirection
    >>> TradeDirection.BUY
    """

    BUY: TradeDirection
    SELL: TradeDirection
    HOLD: TradeDirection

    def __repr__(self) -> str: ...

class TradeType:

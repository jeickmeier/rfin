        Buy / Sell / Hold classification.
    current_weight : float
        Pre-trade portfolio weight.
    target_weight : float
        Post-trade portfolio weight.
    """

    position_id: str
    instrument_id: str
    trade_type: TradeType
    current_quantity: float
    target_quantity: float
    delta_quantity: float
    direction: TradeDirection
    current_weight: float
    target_weight: float

    def __repr__(self) -> str: ...

# ---------------------------------------------------------------------------
# Optimization Result
# ---------------------------------------------------------------------------

class OptimizationResult:
    """Solution of an optimization problem.

    Provides optimal weights, weight deltas, trade lists, and diagnostics
    such as binding constraints and turnover.

    Examples
    --------
    >>> result = problem.optimize(market_context)
    >>> result.objective_value
    0.0523
    >>> result.status.is_feasible()
    True
    >>> trades = result.to_trade_list()
    """

    @property
    def optimal_weights(self) -> dict[str, float]:
        """Optimal weights per position.

        Returns
        -------
        dict[str, float]
            Mapping of position id to target weight.
        """
        ...

    @property
    def current_weights(self) -> dict[str, float]:
        """Pre-trade weights per position.

        Returns
        -------
        dict[str, float]
            Mapping of position id to current weight.
        """
        ...

    @property
    def weight_deltas(self) -> dict[str, float]:
        """Weight changes per position (``optimal - current``).

        Returns
        -------
        dict[str, float]
            Mapping of position id to weight delta.
        """
        ...

    @property
    def objective_value(self) -> float:
        """Objective value at the optimal solution.

        Returns
        -------
        float
            Scalar objective value.
        """
        ...

    @property
    def status(self) -> OptimizationStatus:
        """Optimization status.

        Returns
        -------
        OptimizationStatus
            Status indicating optimality or infeasibility.
        """
        ...

    def to_rebalanced_portfolio(self) -> Portfolio:
        """Generate a new portfolio with quantities adjusted to target weights.

        Returns
        -------
        Portfolio
            Rebalanced portfolio.

        Raises
        ------
        RuntimeError
            If rebalancing fails.
        """
        ...

    def to_trade_list(self) -> list[TradeSpec]:
        """Generate a trade list sorted by absolute quantity delta.

        Returns
        -------
        list[TradeSpec]
            Trades required to move from current to optimal weights.
        """
        ...

    def new_position_trades(self) -> list[TradeSpec]:
        """Get trades for new positions only (from candidates).

        Returns
        -------
        list[TradeSpec]
            Trades for candidate instruments added by the optimizer.
        """
        ...

    def binding_constraints(self) -> dict[str, float]:
        """Get constraints that are binding at the solution (slack ~ 0).

        Returns
        -------
        dict[str, float]
            Mapping of constraint label to slack value.
        """
        ...

    def turnover(self) -> float:
        """Calculate total turnover (sum of absolute weight changes).

        Returns
        -------
        float
            Total portfolio turnover.
        """
        ...

    def __repr__(self) -> str: ...

# ---------------------------------------------------------------------------
# Candidate Position
# ---------------------------------------------------------------------------

class CandidatePosition:
    """Candidate instrument that could be added to the portfolio by the optimizer.

    Examples
    --------
    >>> from finstack.portfolio.optimization import CandidatePosition
    >>> candidate = CandidatePosition.new("bond_1", "fund_1", instrument, "FaceValue")
    >>> candidate = candidate.with_tag("rating", "BBB")
    >>> candidate = candidate.with_max_weight(0.05)
    """

    @staticmethod
    def new(
        id: str,
        entity_id: str,
        instrument: Any,
        unit: str | PositionUnit,
    ) -> CandidatePosition:
        """Create a candidate position.

        Parameters
        ----------
        id : str
            Candidate position identifier.
        entity_id : str
            Owning entity identifier.
        instrument : Any
            Instrument object (Bond, Equity, etc.).
        unit : str or PositionUnit
            Position unit type (``"Units"``, ``"Notional"``, ``"FaceValue"``,
            ``"Percentage"``).

        Returns
        -------
        CandidatePosition
            New candidate.

        Raises
        ------
        ValueError
            If *unit* is not a recognised position unit string.
        """
        ...

    def with_tag(self, key: str, value: str) -> CandidatePosition:
        """Add a tag to the candidate.

        Parameters
        ----------
        key : str
            Tag key.
        value : str
            Tag value.

        Returns
        -------
        CandidatePosition
            New candidate with the tag added.
        """
        ...

    def with_max_weight(self, max: float) -> CandidatePosition:
        """Set the maximum weight for this candidate.

        Parameters
        ----------
        max : float
            Upper weight bound.

        Returns
        -------
        CandidatePosition
            New candidate with maximum weight set.
        """
        ...

    def with_min_weight(self, min: float) -> CandidatePosition:
        """Set the minimum weight (if included) for this candidate.

        Parameters
        ----------
        min : float
            Lower weight bound.

        Returns
        -------
        CandidatePosition
            New candidate with minimum weight set.
        """
        ...

    def __repr__(self) -> str: ...


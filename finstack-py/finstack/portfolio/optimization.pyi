        ...

    def __repr__(self) -> str: ...

# ---------------------------------------------------------------------------
# Constraints
# ---------------------------------------------------------------------------

class Constraint:
    """Declarative constraint specification for the optimizer.

    Constraints are built via static factory methods and added to a
    :class:`PortfolioOptimizationProblem`.

    Examples
    --------
    >>> from finstack.portfolio.optimization import (
    ...     Constraint,
    ...     MetricExpr,
    ...     PerPositionMetric,
    ...     Inequality,
    ... )
    >>> from finstack.valuations.metrics import MetricId
    >>> dur = PerPositionMetric.metric(MetricId.DURATION_MOD)
    >>> Constraint.metric_bound("dur_limit", MetricExpr.weighted_sum(dur), Inequality.LE, 4.0)
    >>> Constraint.tag_exposure_limit("ccc_cap", "rating", "CCC", 0.10)
    >>> Constraint.max_turnover("low_turnover", 0.20)
    """

    @staticmethod
    def metric_bound(
        label: str | None,
        metric: MetricExpr,
        op: Inequality,
        rhs: float,
    ) -> Constraint:
        """General metric bound (e.g., ``duration <= 4.0``).

        Parameters
        ----------
        label : str or None
            Human-readable constraint label.
        metric : MetricExpr
            Portfolio-level metric expression.
        op : Inequality
            Comparison operator (``LE``, ``GE``, or ``EQ``).
        rhs : float
            Right-hand side of the inequality.

        Returns
        -------
        Constraint
            Metric-bound constraint.
        """
        ...

    @staticmethod
    def tag_exposure_limit(
        label: str | None,
        tag_key: str,
        tag_value: str,
        max_share: float,
    ) -> Constraint:
        """Tag exposure limit (e.g., ``rating=CCC weight <= 0.10``).

        Parameters
        ----------
        label : str or None
            Constraint label.
        tag_key : str
            Tag key to filter positions.
        tag_value : str
            Tag value to match.
        max_share : float
            Maximum allowed weight share (0.0 -- 1.0).

        Returns
        -------
        Constraint
            Tag-exposure-limit constraint.
        """
        ...

    @staticmethod
    def tag_exposure_minimum(
        label: str | None,
        tag_key: str,
        tag_value: str,
        min_share: float,
    ) -> Constraint:
        """Minimum tag exposure (e.g., ``rating=IG weight >= 0.50``).

        Parameters
        ----------
        label : str or None
            Constraint label.
        tag_key : str
            Tag key to filter positions.
        tag_value : str
            Tag value to match.
        min_share : float
            Minimum required weight share (0.0 -- 1.0).

        Returns
        -------
        Constraint
            Tag-exposure-minimum constraint.
        """
        ...

    @staticmethod
    def weight_bounds(
        label: str | None,
        filter: PositionFilter,
        min: float,
        max: float,
    ) -> Constraint:
        """Per-position weight bounds for all positions matching *filter*.

        Parameters
        ----------
        label : str or None
            Constraint label.
        filter : PositionFilter
            Position selection filter.
        min : float
            Minimum per-position weight.
        max : float
            Maximum per-position weight.

        Returns
        -------
        Constraint
            Weight-bounds constraint.
        """
        ...

    @staticmethod
    def max_turnover(label: str | None, max_turnover: float) -> Constraint:
        """Maximum total turnover constraint.

        Parameters
        ----------
        label : str or None
            Constraint label.
        max_turnover : float
            Maximum allowed sum of absolute weight changes.

        Returns
        -------
        Constraint
            Max-turnover constraint.
        """
        ...

    @staticmethod
    def max_position_delta(
        label: str | None,
        filter: PositionFilter,
        max_delta: float,
    ) -> Constraint:
        """Maximum single-position weight change.

        Parameters
        ----------
        label : str or None
            Constraint label.
        filter : PositionFilter
            Position selection filter.
        max_delta : float
            Maximum absolute weight change per position.

        Returns
        -------
        Constraint
            Max-position-delta constraint.
        """
        ...

    @staticmethod
    def budget(rhs: float) -> Constraint:
        """Budget / normalisation constraint (typically ``sum w_i == 1.0``).

        Parameters
        ----------
        rhs : float
            Target budget value.

        Returns
        -------
        Constraint
            Budget constraint.
        """
        ...

    def label(self) -> str | None:
        """Return the constraint label, if set.

        Returns
        -------
        str or None
            Human-readable label.
        """
        ...

    def __repr__(self) -> str: ...


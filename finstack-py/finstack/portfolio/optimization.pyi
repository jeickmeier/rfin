    >>> PositionFilter.by_tag("rating", "HY")
    >>> PositionFilter.by_position_ids(["pos_1", "pos_2"])
    """

    @staticmethod
    def all() -> PositionFilter:
        """All positions in the portfolio.

        Returns
        -------
        PositionFilter
            Unfiltered selection.
        """
        ...

    @staticmethod
    def by_entity_id(entity_id: str) -> PositionFilter:
        """Filter by entity identifier.

        Parameters
        ----------
        entity_id : str
            Entity to select.

        Returns
        -------
        PositionFilter
            Entity-based filter.
        """
        ...

    @staticmethod
    def by_tag(key: str, value: str) -> PositionFilter:
        """Filter by tag key/value pair.

        Parameters
        ----------
        key : str
            Tag key.
        value : str
            Tag value to match.

        Returns
        -------
        PositionFilter
            Tag-based filter.
        """
        ...

    @staticmethod
    def by_position_ids(position_ids: list[str]) -> PositionFilter:
        """Filter by explicit list of position identifiers.

        Parameters
        ----------
        position_ids : list[str]
            Position identifiers to include.

        Returns
        -------
        PositionFilter
            Position-id-based filter.
        """
        ...

    @staticmethod
    def not_(filter: PositionFilter) -> PositionFilter:
        """Exclude positions matching the inner filter.

        Parameters
        ----------
        filter : PositionFilter
            Filter whose matches should be excluded.

        Returns
        -------
        PositionFilter
            Negated filter.

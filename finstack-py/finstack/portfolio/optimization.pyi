class TradeUniverse:
    """Defines which instruments the optimizer is allowed to trade.

    Examples
    --------
    >>> from finstack.portfolio.optimization import TradeUniverse, PositionFilter
    >>> universe = TradeUniverse.all_positions()
    >>> universe = TradeUniverse.filtered(PositionFilter.by_tag("rating", "HY"))
    >>> universe = universe.with_candidate(candidate)
    """

    @staticmethod
    def all_positions() -> TradeUniverse:
        """Create a universe where all existing positions are tradeable.

        Returns
        -------
        TradeUniverse
            Universe containing all positions.
        """
        ...

    @staticmethod
    def filtered(filter: PositionFilter) -> TradeUniverse:
        """Create a universe with only specific positions tradeable.

        Parameters
        ----------
        filter : PositionFilter
            Filter determining tradeable positions.

        Returns
        -------
        TradeUniverse
            Filtered universe.
        """
        ...

    def with_candidate(self, candidate: CandidatePosition) -> TradeUniverse:
        """Add a candidate position to the universe.

        Parameters
        ----------
        candidate : CandidatePosition
            Candidate to add.

        Returns
        -------
        TradeUniverse
            New universe with the candidate included.
        """
        ...

    def with_candidates(self, candidates: list[CandidatePosition]) -> TradeUniverse:
        """Add multiple candidate positions.

        Parameters
        ----------
        candidates : list[CandidatePosition]
            Candidates to add.

        Returns
        -------
        TradeUniverse
            New universe with the candidates included.
        """
        ...

    def with_held_positions(self, filter: PositionFilter) -> TradeUniverse:
        """Set positions to hold constant (not trade).

        Parameters
        ----------
        filter : PositionFilter
            Positions to hold.

        Returns
        -------
        TradeUniverse
            New universe with held positions.
        """
        ...

    def allow_shorting_candidates(self) -> TradeUniverse:
        """Allow short selling of candidate positions.

        Returns
        -------
        TradeUniverse
            New universe with shorting enabled for candidates.
        """
        ...

    def __repr__(self) -> str: ...

# ---------------------------------------------------------------------------
# Optimization Problem
# ---------------------------------------------------------------------------

class PortfolioOptimizationProblem:
    """Complete optimization problem specification.

    Build a problem from a portfolio and objective, add constraints and
    a trade universe, then call :meth:`optimize` to solve.

    Examples
    --------
    >>> from finstack.portfolio.optimization import (
    ...     PortfolioOptimizationProblem,
    ...     Objective,
    ...     MetricExpr,
    ...     PerPositionMetric,
    ...     Constraint,
    ... )
    >>> from finstack.valuations.metrics import MetricId
    >>> ytm = PerPositionMetric.metric(MetricId.YTM)
    >>> obj = Objective.maximize(MetricExpr.value_weighted_average(ytm))
    >>> problem = PortfolioOptimizationProblem.new(portfolio, obj)
    >>> problem = problem.with_constraint(Constraint.tag_exposure_limit(None, "rating", "CCC", 0.10))
    >>> result = problem.optimize(market_context)
    """

    weighting: WeightingScheme
    """Weighting scheme for the optimisation (write-only setter)."""

    missing_metric_policy: MissingMetricPolicy
    """Policy for positions missing a required metric (write-only setter)."""

    label: str | None
    """Human-readable label for the problem (write-only setter)."""

    @staticmethod
    def new(portfolio: Portfolio, objective: Objective) -> PortfolioOptimizationProblem:
        """Create a basic problem optimizing all positions in the portfolio.

        Parameters
        ----------
        portfolio : Portfolio
            Portfolio to optimize.
        objective : Objective
            Optimization objective.

        Returns
        -------
        PortfolioOptimizationProblem
            New optimization problem.
        """
        ...

    def with_trade_universe(self, universe: TradeUniverse) -> PortfolioOptimizationProblem:
        """Set the trade universe.

        Parameters
        ----------
        universe : TradeUniverse
            Trade universe definition.

        Returns
        -------
        PortfolioOptimizationProblem
            New problem with the universe set.
        """
        ...

    def with_constraint(self, constraint: Constraint) -> PortfolioOptimizationProblem:
        """Add a single constraint.

        Parameters
        ----------
        constraint : Constraint
            Constraint to add.

        Returns
        -------
        PortfolioOptimizationProblem
            New problem with the constraint added.
        """
        ...

    def with_constraints(self, constraints: list[Constraint]) -> PortfolioOptimizationProblem:
        """Add multiple constraints.

        Parameters
        ----------
        constraints : list[Constraint]
            Constraints to add.

        Returns
        -------
        PortfolioOptimizationProblem
            New problem with the constraints added.
        """
        ...

    def optimize(
        self,
        market_context: MarketContext,
        config: FinstackConfig | None = None,
    ) -> OptimizationResult:
        """Solve the optimization problem.

        Parameters
        ----------
        market_context : MarketContext
            Market data context for metric evaluation.
        config : FinstackConfig or None, optional
            Configuration overrides.

        Returns

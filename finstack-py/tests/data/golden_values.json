{
  "test_cases": {
    "money_arithmetic": {
      "inputs": {
        "m1": { "amount": 100.5, "currency": "USD" },
        "m2": { "amount": 20.25, "currency": "USD" }
      },
      "expected": {
        "add": { "amount": 120.75, "currency": "USD" },
        "subtract": { "amount": 80.25, "currency": "USD" },
        "multiply_2": { "amount": 201.0, "currency": "USD" },
        "divide_2": { "amount": 50.25, "currency": "USD" }
      }
    },
    "day_count_act360": {
      "inputs": {
        "start_date": "2024-01-01",
        "end_date": "2024-07-01"
      },
      "expected": {
        "year_fraction": 0.5055555555555555,
        "tolerance": 1e-12
      }
    },
    "period_building": {
      "inputs": {
        "spec": "2024Q1..Q2",
        "actuals_until": "2024Q1"
      },
      "expected": {
        "total_periods": 2,
        "period_ids": ["2024Q1", "2024Q2"],
        "is_actual": [true, false]
      }
    },
    "bond_pricing_treasury": {
      "description": "5y semi-annual fixed coupon bond discounted against a flat Act/365F curve",
      "inputs": {
        "instrument_id": "TREASURY-001",
        "notional": 1000000.0,
        "currency": "USD",
        "issue_date": "2024-01-01",
        "maturity_date": "2029-01-01",
        "coupon_rate": 0.045,
        "frequency": "semiannual",
        "day_count": "thirty_360",
        "disc_id": "USD-OIS",
        "curve_knots": [[0.0, 1.0], [1.0, 0.95], [5.0, 0.75]],
        "curve_day_count": "act_365f",
        "as_of": "2024-01-01"
      },
      "expected": {
        "pv": 943101.7231340461,
        "currency": "USD",
        "tolerance": 1.0
      }
    },
    "irs_valuation": {
      "description": "5y semi-annual IRS (pay fixed 4.5%, receive 3M LIBOR) discounted flat Act/365F",
      "inputs": {
        "instrument_id": "IRS-001",
        "notional": 10000000.0,
        "currency": "USD",
        "maturity_date": "2029-01-01",
        "fixed_rate": 0.045,
        "frequency": "semiannual",
        "disc_id": "USD-OIS",
        "fwd_id": "USD-LIBOR",
        "disc_curve_knots": [[0.0, 1.0], [1.0, 0.95], [5.0, 0.75]],
        "fwd_curve_knots": [[0.0, 0.04], [1.0, 0.04], [5.0, 0.04]],
        "fwd_tenor_years": 0.25,
        "as_of": "2024-01-01"
      },
      "expected": {
        "pv": -32957.403462881106,
        "currency": "USD",
        "tolerance": 1.0
      }
    }
  }
}

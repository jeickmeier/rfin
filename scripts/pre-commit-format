#!/bin/bash
# Pre-commit hook for code formatting
# This hook runs formatters before allowing a commit
#
# To install:
#   cp scripts/pre-commit-format .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or use pre-commit:
#   pre-commit install

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo -e "${YELLOW}Running pre-commit formatting checks...${NC}"

# Check if we're in a git repo
if ! git rev-parse --git-dir > /dev/null 2>&1; then
    echo -e "${RED}Not in a git repository${NC}"
    exit 1
fi

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | tr '\n' ' ')

# Exit if no files are staged
if [[ -z "$STAGED_FILES" ]]; then
    echo -e "${GREEN}No files staged for commit${NC}"
    exit 0
fi

# Run formatters on staged files
echo "Checking staged files: $STAGED_FILES"

# Create a temporary directory for formatting
TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

# Copy staged files to temp directory
for file in $STAGED_FILES; do
    if [[ -f "$file" ]]; then
        mkdir -p "$TEMP_DIR/$(dirname "$file")"
        cp "$file" "$TEMP_DIR/$file"
    fi
done

# Change to temp directory
cd "$TEMP_DIR"

# Run formatters
FAILED=0

# Rust files
if echo "$STAGED_FILES" | grep -q "\.rs$"; then
    echo -e "\n${YELLOW}Checking Rust files...${NC}"
    if ! cargo fmt --all -- --check > /dev/null 2>&1; then
        echo -e "${RED}Rust files need formatting${NC}"
        echo "Run: cargo fmt"
        FAILED=1
    fi
fi

# Python files
if echo "$STAGED_FILES" | grep -E "\.(py|pyi)$"; then
    echo -e "\n${YELLOW}Checking Python files...${NC}"
    if ! uv run ruff format . --check > /dev/null 2>&1; then
        echo -e "${RED}Python files need formatting${NC}"
        echo "Run: uv run ruff format ."
        FAILED=1
    fi

    if ! uv run ruff check . --no-fix > /dev/null 2>&1; then
        echo -e "${RED}Python files have lint errors${NC}"
        echo "Run: uv run ruff check . --fix"
        FAILED=1
    fi
fi

# TypeScript/JavaScript files (WASM)
if echo "$STAGED_FILES" | grep -E "^finstack-wasm/.*\.(ts|tsx|js|jsx)$"; then
    echo -e "\n${YELLOW}Checking WASM/TS files...${NC}"
    cd finstack-wasm
    if ! npm run format -- --check . > /dev/null 2>&1; then
        echo -e "${RED}WASM/TS files need formatting${NC}"
        echo "Run: cd finstack-wasm && npm run format:fix ."
        FAILED=1
    fi
    cd ..
fi

# TypeScript/JavaScript files (UI)
if echo "$STAGED_FILES" | grep -E "^finstack-ui/.*\.(ts|tsx|js|jsx)$"; then
    echo -e "\n${YELLOW}Checking UI/TS files...${NC}"
    cd finstack-ui
    if ! npm run format -- --check "**/*.{js,jsx,ts,tsx}" > /dev/null 2>&1; then
        echo -e "${RED}UI/TS files need formatting${NC}"
        echo "Run: cd finstack-ui && npm run format:fix \"**/*.{js,jsx,ts,tsx}\""
        FAILED=1
    fi
    cd ..
fi

# Markdown files
if echo "$STAGED_FILES" | grep -E "\.md$"; then
    echo -e "\n${YELLOW}Checking Markdown files...${NC}"
    if ! npx markdownlint-cli2 "**/*.md" "#node_modules" "#**/node_modules/**" "#finstack-wasm/pkg" "#.git" "#CHANGELOG.md" "#PARITY_AUDIT.md" "#.cursor" "#.agent" "#.zenflow" "#.zencoder" "#**/target/**" > /dev/null 2>&1; then
        echo -e "${RED}Markdown files need formatting${NC}"
        echo "Run: npx markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#**/node_modules/**\" \"#finstack-wasm/pkg\" \"#.git\" \"#CHANGELOG.md\" \"#PARITY_AUDIT.md\" \"#.cursor\" \"#.agent\" \"#.zenflow\" \"#.zencoder\" \"#**/target/**\" --fix"
        FAILED=1
    fi
fi

# Return to original directory
cd - > /dev/null

# Check result
if [[ $FAILED -eq 1 ]]; then
    echo -e "\n${RED}❌ Pre-commit checks failed!${NC}"
    echo ""
    echo "Please fix the above issues before committing."
    echo "You can run './scripts/format-code' to fix all formatting issues."
    exit 1
else
    echo -e "\n${GREEN}✅ All formatting checks passed!${NC}"
    exit 0
fi

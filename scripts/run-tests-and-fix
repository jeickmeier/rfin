#!/bin/bash

# /run-tests-and-fix - Comprehensive test and auto-fix workflow for RFin project
# This script runs tests across all languages (Rust, Python, TypeScript) and
# automatically fixes common issues to ensure code quality before commits/merges

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# If script is in project root, use it directly. Otherwise, check parent.
if [[ -f "$SCRIPT_DIR/Cargo.toml" ]]; then
    PROJECT_ROOT="$SCRIPT_DIR"
elif [[ -f "$(dirname "$SCRIPT_DIR")/Cargo.toml" ]]; then
    PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
else
    # Fallback to current directory
    PROJECT_ROOT="$(pwd)"
fi
LOG_FILE="$PROJECT_ROOT/.test-fix.log"
FAILED_STEPS=()
FIXED_STEPS=()
SKIP_SLOW=${SKIP_SLOW:-false}
COVERAGE=${COVERAGE:-false}
VERBOSE=${VERBOSE:-false}

# Logging functions
log() {
    echo -e "${BLUE}[$(date '+%Y-%m-%d %H:%M:%S')]${NC} $1" | tee -a "$LOG_FILE"
}

log_success() {
    echo -e "${GREEN}✅ $1${NC}" | tee -a "$LOG_FILE"
}

log_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}" | tee -a "$LOG_FILE"
}

log_error() {
    echo -e "${RED}❌ $1${NC}" | tee -a "$LOG_FILE"
}

log_info() {
    echo -e "${PURPLE}ℹ️  $1${NC}" | tee -a "$LOG_FILE"
}

log_section() {
    echo -e "\n${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}🚀 $1${NC}"
    echo -e "${CYAN}════════════════════════════════════════════════════════════════${NC}\n"
}

# Error handling
handle_error() {
    local step="$1"
    local fix_command="$2"
    FAILED_STEPS+=("$step")
    log_error "Step failed: $step"

    if [[ -n "$fix_command" ]]; then
        log_info "Attempting automatic fix..."
        if eval "$fix_command"; then
            log_success "Fixed: $step"
            FIXED_STEPS+=("$step")
            return 0
        else
            log_error "Automatic fix failed for: $step"
            return 1
        fi
    fi
    return 1
}

# Check if command exists
check_command() {
    if ! command -v "$1" &> /dev/null; then
        log_error "Required command not found: $1"
        return 1
    fi
}

# Rust functions
run_rust_fmt() {
    log_section "Rust Formatting Check"

    if ! cargo fmt --all -- --check; then
        handle_error "Rust formatting" "cargo fmt --all"
        return $?
    fi

    log_success "Rust formatting is correct"
    return 0
}

run_rust_clippy() {
    log_section "Rust Linting (Clippy)"

    if ! PYO3_PYTHON=python3 CARGO_INCREMENTAL=1 cargo clippy --workspace --all-targets --all-features -- -D warnings; then
        handle_error "Rust clippy" "cargo clippy --workspace --all-targets --all-features --fix --allow-dirty --allow-staged"
        return $?
    fi

    log_success "Rust passes all clippy lints"
    return 0
}

run_rust_tests() {
    log_section "Rust Tests"

    # Install nextest if needed
    if ! check_command cargo-nextest; then
        log_info "Installing cargo-nextest..."
        cargo install cargo-nextest --locked
    fi

    local test_cmd="cargo nextest run --workspace --exclude finstack-py --features mc,test-utils --lib --test '*' --no-fail-fast"

    if [[ "$SKIP_SLOW" == "true" ]]; then
        log_info "Skipping slow Rust tests"
    else
        test_cmd="cargo nextest run --workspace --exclude finstack-py --features mc,slow,test-utils --lib --test '*'"
    fi

    if ! eval "$test_cmd"; then
        log_error "Rust tests failed"
        log_info "Tips to fix Rust test failures:"
        log_info "  1. Check test output for specific failures"
        log_info "  2. Run 'cargo test <test_name>' for individual tests"
        log_info "  3. Ensure all dependencies are up to date"
        return 1
    fi

    log_success "All Rust tests passed"
    return 0
}

run_rust_doc_tests() {
    log_section "Rust Documentation Tests"

    # Check for forbidden doctest ignore
    if rg -n '^[[:space:]]*```[^\n]*\bignore\b' --glob '**/*.rs'; then
        handle_error "Doctest ignore usage" ""
        return $?
    fi

    if ! cargo test --workspace --exclude finstack-py --doc --features mc; then
        log_error "Rust doc tests failed"
        return 1
    fi

    log_success "All Rust doc tests passed"
    return 0
}

# Python functions
setup_python_env() {
    log_section "Python Environment Setup"

    # Check for uv
    if ! check_command uv; then
        log_error "uv is required. Install from https://github.com/astral-sh/uv"
        return 1
    fi

    # Create venv if not exists
    if [[ ! -d ".venv" ]]; then
        log_info "Creating Python virtual environment..."
        uv venv
    fi

    # Activate and install dependencies
    source .venv/bin/activate

    # Install dev dependencies if needed
    if ! pip show pytest &> /dev/null; then
        log_info "Installing Python dependencies..."
        uv pip install maturin pytest pytest-benchmark ruff mypy
    fi

    log_success "Python environment is ready"
    return 0
}

run_python_fmt() {
    log_section "Python Formatting Check (Ruff)"

    source .venv/bin/activate

    if ! ruff format --check .; then
        handle_error "Python formatting" "ruff format ."
        return $?
    fi

    log_success "Python formatting is correct"
    return 0
}

run_python_lint() {
    log_section "Python Linting (Ruff)"

    source .venv/bin/activate

    if ! ruff check .; then
        handle_error "Python linting" "ruff check . --fix --unsafe-fixes"
        return $?
    fi

    log_success "Python passes all ruff checks"
    return 0
}

run_python_tests() {
    log_section "Python Tests"

    source .venv/bin/activate

    # Build Python bindings first
    cd finstack-py
    if ! python -m maturin develop --profile release-perf; then
        log_error "Failed to build Python bindings"
        cd ..
        return 1
    fi
    cd ..

    # Run tests
    if ! uv run pytest finstack-py/tests -v; then
        log_error "Python tests failed"
        log_info "Tips to fix Python test failures:"
        log_info "  1. Check test output for specific failures"
        log_info "  2. Run 'pytest finstack-py/tests -k <test_name>' for specific tests"
        log_info "  3. Ensure Python bindings are built correctly"
        return 1
    fi

    log_success "All Python tests passed"
    return 0
}

# WASM functions
run_wasm_fmt() {
    log_section "WASM Formatting Check"

    cd finstack-wasm

    if ! npm run format:check; then
        handle_error "WASM formatting" "npm run format:fix"
        local result=$?
        cd ..
        return $result
    fi

    cd ..
    log_success "WASM formatting is correct"
    return 0
}

run_wasm_lint() {
    log_section "WASM Linting (ESLint)"

    cd finstack-wasm

    if ! npm run lint; then
        handle_error "WASM linting" "npm run lint:fix"
        local result=$?
        cd ..
        return $result
    fi

    cd ..
    log_success "WASM passes all ESLint checks"
    return 0
}

run_wasm_tests() {
    log_section "WASM Tests"

    cd finstack-wasm

    # Build WASM package first
    if ! wasm-pack build --target web; then
        log_error "Failed to build WASM package"
        cd ..
        return 1
    fi

    # Run tests
    if ! npm run test; then
        log_error "WASM tests failed"
        cd ..
        return 1
    fi

    cd ..
    log_success "All WASM tests passed"
    return 0
}

# UI functions
run_ui_fmt() {
    log_section "UI Formatting Check"

    cd finstack-ui

    if ! npm run format; then
        handle_error "UI formatting" "npm run format:fix"
        local result=$?
        cd ..
        return $result
    fi

    cd ..
    log_success "UI formatting is correct"
    return 0
}

run_ui_lint() {
    log_section "UI Linting (ESLint)"

    cd finstack-ui

    if ! npm run lint; then
        handle_error "UI linting" "npm run lint:fix"
        local result=$?
        cd ..
        return $result
    fi

    cd ..
    log_success "UI passes all ESLint checks"
    return 0
}

run_ui_tests() {
    log_section "UI Tests"

    cd finstack-ui

    if ! npm run test -- run; then
        log_error "UI tests failed"
        cd ..
        return 1
    fi

    cd ..
    log_success "All UI tests passed"
    return 0
}

# Coverage functions
run_coverage() {
    log_section "Code Coverage Analysis"

    # Rust coverage
    log_info "Running Rust coverage..."
    if command -v cargo-llvm-cov &> /dev/null; then
        cargo llvm-cov --workspace --exclude finstack-py --exclude finstack-wasm --html --ignore-filename-regex '(tests?/|target/|\.cargo/|.*finstack-py/.*|.*finstack-wasm/.*)'
        log_success "Rust coverage report generated in target/llvm-cov/html/"
    else
        log_warning "cargo-llvm-cov not installed. Install with: cargo install cargo-llvm-cov"
    fi

    # Python coverage
    log_info "Running Python coverage..."
    source .venv/bin/activate
    cd finstack-py
    if pytest --cov=finstack --cov-report=html tests; then
        log_success "Python coverage report generated in finstack-py/htmlcov/"
    else
        log_warning "Python coverage failed"
    fi
    cd ..

    # UI coverage
    log_info "Running UI coverage..."
    cd finstack-ui
    if npm run test:coverage; then
        log_success "UI coverage report generated in finstack-ui/coverage/"
    else
        log_warning "UI coverage failed"
    fi
    cd ..

    return 0
}

# Pre-commit integration
run_pre_commit() {
    log_section "Pre-commit Hooks"

    if [[ -d ".venv" ]]; then
        source .venv/bin/activate
    fi

    if ! pre-commit run --all-files; then
        log_error "Pre-commit hooks failed"
        log_info "Run 'pre-commit run --all-files' to fix issues"
        return 1
    fi

    log_success "All pre-commit hooks passed"
    return 0
}

# Schema validation
run_schema_check() {
    log_section "Schema Validation"

    if ! cargo nextest run -p finstack-valuations schema_parity --no-fail-fast; then
        log_error "Schema parity tests failed"
        return 1
    fi

    if ! cargo test -p finstack-valuations test_instrument_schema_enum_parity --no-fail-fast; then
        log_error "Schema enum parity test failed"
        return 1
    fi

    log_success "All schema validation tests passed"
    return 0
}

# Main execution
main() {
    local exit_code=0

    # Initialize log
    echo "Test and Fix Log - $(date)" > "$LOG_FILE"

    # Show banner
    echo -e "${CYAN}"
    echo -e "${NC}"
    echo -e "${BLUE}====================================${NC}\n"
    echo -e "${BLUE}RFin Test and Auto-Fix Workflow${NC}"
    echo -e "${BLUE}====================================${NC}\n"

    # Parse arguments
    local rust_only=false
    local python_only=false
    local wasm_only=false
    local ui_only=false
    local no_fix=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --rust-only)
                rust_only=true
                shift
                ;;
            --python-only)
                python_only=true
                shift
                ;;
            --wasm-only)
                wasm_only=true
                shift
                ;;
            --ui-only)
                ui_only=true
                shift
                ;;
            --no-fix)
                no_fix=true
                shift
                ;;
            --coverage)
                COVERAGE=true
                shift
                ;;
            --skip-slow)
                SKIP_SLOW=true
                shift
                ;;
            --verbose)
                VERBOSE=true
                shift
                ;;
            --help|-h)
                cat << EOF
Usage: $0 [OPTIONS]

Options:
  --rust-only      Run only Rust tests and checks
  --python-only    Run only Python tests and checks
  --wasm-only      Run only WASM tests and checks
  --ui-only        Run only UI tests and checks
  --no-fix         Skip automatic fixes
  --coverage       Generate coverage reports
  --skip-slow      Skip slow-running tests
  --verbose        Enable verbose output
  --help, -h       Show this help message

Environment Variables:
  SKIP_SLOW=true   Skip slow tests
  COVERAGE=true    Generate coverage reports
  VERBOSE=true     Enable verbose output

Examples:
  $0                    # Run all tests and fixes
  $0 --rust-only        # Run only Rust tests
  $0 --no-fix --coverage # Run all tests with coverage, no fixes
EOF
                exit 0
                ;;
            *)
                log_error "Unknown option: $1"
                exit 1
                ;;
        esac
    done

    # Change to project root
    log_info "Changing to project root: $PROJECT_ROOT"
    cd "$PROJECT_ROOT" || {
        log_error "Failed to change to project root: $PROJECT_ROOT"
        exit 1
    }
    log_info "Current directory: $(pwd)"
    log_info "Looking for Cargo.toml..."
    if [[ -f "Cargo.toml" ]]; then
        log_success "Found Cargo.toml"
    else
        log_error "Cargo.toml not found in current directory"
        exit 1
    fi

    # Check dependencies
    log_info "Checking dependencies..."
    check_command cargo || exit 1
    check_command node || exit 1
    check_command npm || exit 1

    # Run tests based on options
    if [[ "$rust_only" == "true" ]]; then
        run_rust_fmt || exit_code=1
        run_rust_clippy || exit_code=1
        run_rust_tests || exit_code=1
        run_rust_doc_tests || exit_code=1
    elif [[ "$python_only" == "true" ]]; then
        setup_python_env || exit_code=1
        run_python_fmt || exit_code=1
        run_python_lint || exit_code=1
        run_python_tests || exit_code=1
    elif [[ "$wasm_only" == "true" ]]; then
        run_wasm_fmt || exit_code=1
        run_wasm_lint || exit_code=1
        run_wasm_tests || exit_code=1
    elif [[ "$ui_only" == "true" ]]; then
        run_ui_fmt || exit_code=1
        run_ui_lint || exit_code=1
        run_ui_tests || exit_code=1
    else
        # Run all checks
        log_section "Running All Quality Checks"

        # Rust
        run_rust_fmt || exit_code=1
        run_rust_clippy || exit_code=1
        run_rust_tests || exit_code=1
        run_rust_doc_tests || exit_code=1

        # Python
        setup_python_env || exit_code=1
        run_python_fmt || exit_code=1
        run_python_lint || exit_code=1
        run_python_tests || exit_code=1

        # WASM
        run_wasm_fmt || exit_code=1
        run_wasm_lint || exit_code=1
        run_wasm_tests || exit_code=1

        # UI
        run_ui_fmt || exit_code=1
        run_ui_lint || exit_code=1
        run_ui_tests || exit_code=1

        # Schema validation
        run_schema_check || exit_code=1

        # Pre-commit hooks
        run_pre_commit || exit_code=1
    fi

    # Coverage if requested
    if [[ "$COVERAGE" == "true" ]]; then
        run_coverage
    fi

    # Summary
    echo -e "\n${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}📊 Summary${NC}"
    echo -e "${CYAN}════════════════════════════════════════════════════════════════${NC}"

    if [[ $exit_code -eq 0 ]]; then
        log_success "All checks passed! ✨"
        if [[ ${#FIXED_STEPS[@]} -gt 0 ]]; then
            log_info "Auto-fixed issues: ${#FIXED_STEPS[@]}"
            printf '  %s\n' "${FIXED_STEPS[@]}"
        fi
    else
        log_error "Some checks failed ❌"
        if [[ ${#FAILED_STEPS[@]} -gt 0 ]]; then
            log_error "Failed steps: ${#FAILED_STEPS[@]}"
            printf '  %s\n' "${FAILED_STEPS[@]}"
        fi
    fi

    echo -e "\n${BLUE}Log file: $LOG_FILE${NC}"

    exit $exit_code
}

# Run main function with all arguments
main "$@"

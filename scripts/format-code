#!/bin/bash
# Code formatting script for RFin project
# Usage: ./scripts/format-code [options]
#
# Options:
#   --check-only    Only check formatting without fixing
#   --rust-only     Format only Rust code
#   --python-only   Format only Python code
#   --wasm-only     Format only WASM/TS code
#   --ui-only       Format only UI/TS code
#   --markdown-only Format only Markdown files
#   --verbose       Show detailed output
#   --help          Show this help message

set -e

# Default values
CHECK_ONLY=false
RUST_ONLY=false
PYTHON_ONLY=false
WASM_ONLY=false
UI_ONLY=false
MARKDOWN_ONLY=false
VERBOSE=false

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${BLUE}[FORMAT]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --check-only)
            CHECK_ONLY=true
            shift
            ;;
        --rust-only)
            RUST_ONLY=true
            shift
            ;;
        --python-only)
            PYTHON_ONLY=true
            shift
            ;;
        --wasm-only)
            WASM_ONLY=true
            shift
            ;;
        --ui-only)
            UI_ONLY=true
            shift
            ;;
        --markdown-only)
            MARKDOWN_ONLY=true
            shift
            ;;
        --verbose)
            VERBOSE=true
            shift
            ;;
        --help)
            echo "Code formatting script for RFin project"
            echo ""
            echo "Usage: $0 [options]"
            echo ""
            echo "Options:"
            echo "  --check-only    Only check formatting without fixing"
            echo "  --rust-only     Format only Rust code"
            echo "  --python-only   Format only Python code"
            echo "  --wasm-only     Format only WASM/TS code"
            echo "  --ui-only       Format only UI/TS code"
            echo "  --markdown-only Format only Markdown files"
            echo "  --verbose       Show detailed output"
            echo "  --help          Show this help message"
            echo ""
            echo "Examples:"
            echo "  $0                 # Format all code"
            echo "  $0 --check-only    # Check formatting without fixing"
            echo "  $0 --rust-only     # Format only Rust code"
            exit 0
            ;;
        *)
            print_error "Unknown option: $1"
            echo "Use --help for usage information"
            exit 1
            ;;
    esac
done

# Check if we're in the project root
if [[ ! -f "Cargo.toml" || ! -f "pyproject.toml" ]]; then
    print_error "Must be run from project root directory"
    exit 1
fi

# Function to check if command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Function to run formatter with error handling
run_formatter() {
    local name="$1"
    local check_cmd="$2"
    local fix_cmd="$3"
    local dir="$4"

    print_status "Running $name..."

    if [[ -n "$dir" ]]; then
        pushd "$dir" > /dev/null
    fi

    if [[ "$CHECK_ONLY" == "true" ]]; then
        if eval "$check_cmd"; then
            print_success "$name check passed"
        else
            print_error "$name check failed"
            if [[ -n "$dir" ]]; then
                popd > /dev/null
            fi
            exit 1
        fi
    else
        if eval "$fix_cmd"; then
            print_success "$name completed"
        else
            print_warning "$name had issues (non-critical)"
        fi
    fi

    if [[ -n "$dir" ]]; then
        popd > /dev/null
    fi
}

# Main formatting logic
main() {
    print_status "Starting code formatting..."

    if [[ "$VERBOSE" == "true" ]]; then
        echo "CHECK_ONLY: $CHECK_ONLY"
        echo "RUST_ONLY: $RUST_ONLY"
        echo "PYTHON_ONLY: $PYTHON_ONLY"
        echo "WASM_ONLY: $WASM_ONLY"
        echo "UI_ONLY: $UI_ONLY"
        echo "MARKDOWN_ONLY: $MARKDOWN_ONLY"
    fi

    # Check dependencies
    if ! command_exists cargo; then
        print_error "cargo not found. Please install Rust."
        exit 1
    fi

    if ! command_exists uv; then
        print_error "uv not found. Please install uv."
        exit 1
    fi

    if ! command_exists npm; then
        print_error "npm not found. Please install Node.js."
        exit 1
    fi

    # Format Rust code
    if [[ "$RUST_ONLY" == "true" || ($PYTHON_ONLY == "false" && $WASM_ONLY == "false" && $UI_ONLY == "false" && $MARKDOWN_ONLY == "false") ]]; then
        if [[ "$CHECK_ONLY" == "true" ]]; then
            run_formatter "Rust formatting" \
                "cargo fmt --all -- --check" \
                "cargo fmt --all" \
                ""
        else
            run_formatter "Rust formatting" \
                "cargo fmt --all -- --check" \
                "cargo fmt --all" \
                ""
        fi

        run_formatter "Rust linting" \
            "cargo clippy --workspace --all-targets --all-features -- -D warnings" \
            "cargo clippy --workspace --all-targets --all-features --fix --allow-dirty -- -D warnings" \
            ""
    fi

    # Format Python code
    if [[ "$PYTHON_ONLY" == "true" || ($RUST_ONLY == "false" && $WASM_ONLY == "false" && $UI_ONLY == "false" && $MARKDOWN_ONLY == "false") ]]; then
        run_formatter "Python formatting" \
            "uv run ruff format . --check" \
            "uv run ruff format ." \
            ""

        run_formatter "Python linting" \
            "uv run ruff check . --no-fix" \
            "uv run ruff check . --fix --unsafe-fixes" \
            ""
    fi

    # Format WASM/TS code
    if [[ "$WASM_ONLY" == "true" || ($RUST_ONLY == "false" && $PYTHON_ONLY == "false" && $UI_ONLY == "false" && $MARKDOWN_ONLY == "false") ]]; then
        if [[ ! -d "finstack-wasm" ]]; then
            print_error "finstack-wasm directory not found"
            exit 1
        fi

        # Install dependencies if needed
        if [[ ! -d "finstack-wasm/node_modules" ]]; then
            print_status "Installing WASM dependencies..."
            cd finstack-wasm && npm ci && cd ..
        fi

        run_formatter "WASM/TS formatting" \
            "cd finstack-wasm && npm run format -- --check ." \
            "cd finstack-wasm && npm run format:fix ." \
            "finstack-wasm"

        run_formatter "WASM/TS linting" \
            "cd finstack-wasm && npm run lint" \
            "cd finstack-wasm && npm run lint:fix || true" \
            "finstack-wasm"
    fi

    # Format UI/TS code
    if [[ "$UI_ONLY" == "true" || ($RUST_ONLY == "false" && $PYTHON_ONLY == "false" && $WASM_ONLY == "false" && $MARKDOWN_ONLY == "false") ]]; then
        if [[ ! -d "finstack-ui" ]]; then
            print_error "finstack-ui directory not found"
            exit 1
        fi

        # Install dependencies if needed
        if [[ ! -d "finstack-ui/node_modules" ]]; then
            print_status "Installing UI dependencies..."
            cd finstack-ui && npm ci && cd ..
        fi

        run_formatter "UI/TS formatting" \
            "cd finstack-ui && npm run format -- --check \"**/*.{js,jsx,ts,tsx,json,md,css}\"" \
            "cd finstack-ui && npm run format:fix \"**/*.{js,jsx,ts,tsx,json,md,css}\"" \
            "finstack-ui"

        run_formatter "UI/TS linting" \
            "cd finstack-ui && npm run lint" \
            "cd finstack-ui && npm run lint:fix || true" \
            "finstack-ui"
    fi

    # Format Markdown files
    if [[ "$MARKDOWN_ONLY" == "true" || ($RUST_ONLY == "false" && $PYTHON_ONLY == "false" && $WASM_ONLY == "false" && $UI_ONLY == "false") ]]; then
        # Install markdownlint if needed
        if ! command_exists npx; then
            print_error "npx not found. Please install Node.js."
            exit 1
        fi

        run_formatter "Markdown formatting" \
            "npx markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#finstack-wasm/pkg\" \"#.git\"" \
            "npx markdownlint-cli2 \"**/*.md\" \"#node_modules\" \"#finstack-wasm/pkg\" \"#.git\" --fix" \
            ""
    fi

    # Show summary
    if [[ "$CHECK_ONLY" == "true" ]]; then
        print_success "All formatting checks passed! ✨"
    else
        print_success "Code formatting completed! ✨"

        # Check if there are changes
        if [[ -n $(git status --porcelain 2>/dev/null) ]]; then
            print_warning "Changes were made. Please review and commit:"
            git status --short
        fi
    fi
}

# Run main function
main "$@"

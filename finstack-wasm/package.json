{
  "name": "finstack-wasm",
  "version": "0.1.0",
  "type": "module",
  "description": "WebAssembly bindings for Finstack - high-performance financial computation library for bonds, derivatives, and portfolio analytics",
  "main": "./pkg/finstack_wasm.js",
  "types": "./pkg/finstack_wasm.d.ts",
  "files": [
    "pkg/**",
    "pkg-node/**",
    "snippets/**"
  ],
  "exports": {
    ".": {
      "types": "./pkg/finstack_wasm.d.ts",
      "default": "./pkg/finstack_wasm.js"
    },
    "./package.json": "./package.json",
    "./pkg/finstack_wasm_bg.wasm": "./pkg/finstack_wasm_bg.wasm"
  },
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg",
    "build:node": "wasm-pack build --target nodejs --out-dir pkg-node",
    "build:optimized": "wasm-pack build --target web --out-dir pkg && npm run optimize",
    "prepare": "npm run build",
    "docs:check": "node scripts/check-dts-docs.mjs",
    "optimize": "command -v wasm-opt >/dev/null 2>&1 && wasm-opt -Oz -o pkg/finstack_wasm_bg.wasm pkg/finstack_wasm_bg.wasm || echo 'wasm-opt not found, skipping optimization'",
    "test": "wasm-pack test --node",
    "test:browser": "wasm-pack test --chrome --headless",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "npm run format",
    "examples:install": "cd examples && npm install",
    "examples:dev": "cd examples && npm run dev",
    "examples:build": "cd examples && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rustfin/rfin"
  },
  "homepage": "https://github.com/rustfin/rfin#readme",
  "bugs": {
    "url": "https://github.com/rustfin/rfin/issues"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "finance",
    "rust",
    "derivatives",
    "bonds",
    "pricing",
    "fixed-income",
    "rates",
    "credit",
    "fx",
    "equity",
    "options",
    "swaps",
    "portfolio",
    "risk",
    "calibration",
    "monte-carlo",
    "structured-products"
  ],
  "author": "RustFin Contributors",
  "license": "MIT OR Apache-2.0",
  "devDependencies": {
    "@wasm-tool/wasm-pack-plugin": "^1.7.0",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "typescript": "^5.9.3"
  }
}

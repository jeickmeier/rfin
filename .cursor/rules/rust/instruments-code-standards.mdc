## Pricing Module

### Pricing Structure (`pricing/mod.rs`)
```rust
//! {InstrumentType} pricing entrypoints and pricers.

pub mod engine;
pub mod {variant1};
pub mod {variant2};

use crate::instruments::traits::Priceable;
use crate::metrics::MetricId;
use crate::results::ValuationResult;
use finstack_core::dates::Date;
use finstack_core::market_data::MarketContext;
use finstack_core::money::Money;
use finstack_core::Result;

impl Priceable for Variant1Instrument {
    fn value(&self, context: &MarketContext, as_of: Date) -> Result<Money> {
        // Currency validation
        super::helpers::validate_currencies(self.notional, None)?;
        
        // Calculate legs
        let leg1_pv = {variant1}::pv_leg1(self, context, as_of)?;
        let leg2_pv = engine::EngineName::pv_leg2(
            &self.specification,
            &self.schedule,
            self.notional,
            context,
            as_of,
        )?;

        // Net PV based on side
        let net_pv = match self.side {
            SideEnum::ReceiveLeg1 => leg1_pv - leg2_pv,
            SideEnum::PayLeg1 => leg2_pv - leg1_pv,
        }?;

        Ok(net_pv)
    }

    fn price_with_metrics(
        &self,
        context: &MarketContext,
        as_of: Date,
        _metrics: &[MetricId],
    ) -> Result<ValuationResult> {
        let npv = <Self as Priceable>::value(self, context, as_of)?;
        Ok(ValuationResult::stamped(self.id.as_str(), as_of, npv))
    }
}
```


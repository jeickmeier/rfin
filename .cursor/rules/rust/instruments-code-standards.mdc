/// Calculates the present value of the leg for {Variant} {InstrumentType}.
///
/// # Arguments
/// * `instrument` — The {variant} instrument
/// * `context` — Market context containing curves and market data
/// * `as_of` — Valuation date
///
/// # Returns
/// Present value of the leg in the instrument's currency.
pub fn pv_leg(instrument: &VariantInstrument, context: &MarketContext, as_of: Date) -> Result<Money> {
    let (param1, param2) = extract_underlying_data(instrument, context)?;
    let initial = instrument.initial_level.unwrap_or(param1);

    let params = LegParams {
        schedule: &instrument.schedule,
        notional: instrument.notional,
        curve_id: instrument.specification.curve_id.as_str(),
        additional_param: instrument.underlying.param,
        initial_value: Some(initial),
    };

    let model = VariantCalculationModel { 
        instrument, 
        param1, 
        param2 
    };
    
    EngineName::pv_leg_with_model(params, context, as_of, &model)
}

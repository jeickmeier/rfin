## Pricing Module

### Pricing Structure (`pricing/mod.rs`)
```rust
//! {InstrumentType} pricing entrypoints and pricers.

pub mod engine;
pub mod {variant1};
pub mod {variant2};

use crate::instruments::traits::Priceable;
use crate::metrics::MetricId;
use crate::results::ValuationResult;
use finstack_core::dates::Date;
use finstack_core::market_data::MarketContext;
use finstack_core::money::Money;
use finstack_core::Result;

impl Priceable for Variant1Instrument {
    fn value(&self, context: &MarketContext, as_of: Date) -> Result<Money> {
        // Currency validation (generic + instrument-specific when applicable)
        super::helpers::validate_currencies(self.notional, None)?;
        
        // Calculate legs
        let leg1_pv = {variant1}::pv_leg1(self, context, as_of)?;
        let leg2_pv = engine::EngineName::pv_leg2(
            &self.specification,
            &self.schedule,
            self.notional,
            context,
            as_of,
        )?;

        // Net PV based on side
        let net_pv = match self.side {
            SideEnum::ReceiveLeg1 => leg1_pv - leg2_pv,
            SideEnum::PayLeg1 => leg2_pv - leg1_pv,
        }?;

        Ok(net_pv)
    }

    fn price_with_metrics(
        &self,
        context: &MarketContext,
        as_of: Date,
        metrics: &[MetricId],
    ) -> Result<ValuationResult> {
        let base = <Self as Priceable>::value(self, context, as_of)?;
        // Use shared builder to assemble ValuationResult with metrics
        crate::instruments::utils::build_with_metrics_dyn(self, context, as_of, base, metrics)
    }
}
```

### Pricing Engine (`pricing/engine.rs`)
```rust
//! Core {InstrumentType} pricing engine and shared helpers.

use finstack_core::dates::{Date, DayCountCtx};
use finstack_core::market_data::MarketContext;
use finstack_core::money::Money;
use finstack_core::Result;
use finstack_core::F;

use super::super::types::{SpecificationType, ScheduleType};

/// Common {InstrumentType} pricing engine.
///
/// Provides utility functions for calculating present values of instrument legs
/// and other common pricing operations.
pub struct EngineName;

/// Parameters for leg calculation.
#[derive(Debug, Clone)]
pub struct LegParams<'a> {
    /// Schedule specification for payment periods.
    pub schedule: &'a ScheduleType,
    /// Notional amount for the leg.
    pub notional: Money,
    /// Curve identifier.
    pub curve_id: &'a str,
    /// Additional parameters.
    pub additional_param: F,
}

/// Trait for underlying-specific calculation models.
///
/// Implementations of this trait provide the logic for calculating
/// returns or values over a period for different underlying types.
pub trait CalculationModel {
    /// Computes value over a period given parameters.
    ///
    /// # Arguments
    /// * `period_start` — Start date of the period
    /// * `period_end` — End date of the period
    /// * `t_start` — Time from as_of to period start
    /// * `t_end` — Time from as_of to period end
    /// * `initial_value` — Initial value of the underlying
    /// * `context` — Market context for data access
    ///
    /// # Returns
    /// Calculated value as a decimal.
    fn calculate_value(
        &self,
        period_start: Date,
        period_end: Date,
        t_start: F,
        t_end: F,
        initial_value: F,
        context: &MarketContext,
    ) -> Result<F>;
}

impl EngineName {
    /// Calculates the present value of a leg using shared logic.
    ///
    /// This method contains the common period iteration and discounting logic,
    /// while delegating underlying-specific calculations to the model.
    ///
    /// # Arguments
    /// * `params` — Parameters for the leg calculation
    /// * `context` — Market context containing curves and market data
    /// * `as_of` — Valuation date
    /// * `model` — Model implementing CalculationModel for underlying-specific logic
    ///
    /// # Returns
    /// Present value of the leg in the instrument's currency.
    pub fn pv_leg_with_model(
        params: LegParams,
        context: &MarketContext,
        as_of: Date,
        model: &impl CalculationModel,
    ) -> Result<Money> {
        // Implementation
    }

    /// Calculates the present value of another leg.
    ///
    /// # Arguments
    /// * `specification` — Leg specification
    /// * `schedule` — Schedule specification for payment periods
    /// * `notional` — Notional amount for the leg
    /// * `context` — Market context containing curves and market data
    /// * `as_of` — Valuation date
    ///
    /// # Returns
    /// Present value of the leg in the instrument's currency.
    pub fn pv_other_leg(
        specification: &SpecificationType,
        schedule: &ScheduleType,
        notional: Money,
        context: &MarketContext,
        as_of: Date,
    ) -> Result<Money> {
        // Implementation
    }
}

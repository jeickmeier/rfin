/// Common {InstrumentType} pricing engine.
///
/// Provides utility functions for calculating present values of instrument legs
/// and other common pricing operations.
pub struct EngineName;

/// Parameters for leg calculation.
#[derive(Debug, Clone)]
pub struct LegParams<'a> {
    /// Schedule specification for payment periods.
    pub schedule: &'a ScheduleType,
    /// Notional amount for the leg.
    pub notional: Money,
    /// Curve identifier.
    pub curve_id: &'a str,
    /// Additional parameters.
    pub additional_param: F,
}

/// Trait for underlying-specific calculation models.
///
/// Implementations of this trait provide the logic for calculating
/// returns or values over a period for different underlying types.
pub trait CalculationModel {
    /// Computes value over a period given parameters.
    ///
    /// # Arguments
    /// * `period_start` — Start date of the period
    /// * `period_end` — End date of the period
    /// * `t_start` — Time from as_of to period start
    /// * `t_end` — Time from as_of to period end
    /// * `initial_value` — Initial value of the underlying
    /// * `context` — Market context for data access

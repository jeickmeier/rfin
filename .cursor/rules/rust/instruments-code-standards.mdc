### Variant-Specific Pricing (`pricing/{variant}.rs`)
```rust
//! {Variant} {InstrumentType} pricing utilities.

use super::engine::{LegParams, EngineName, CalculationModel};
use crate::instruments::derivatives::{instrument}::{VariantInstrument};
use finstack_core::dates::Date;
use finstack_core::market_data::MarketContext;
use finstack_core::money::Money;
use finstack_core::Result;

fn extract_underlying_data(
    instrument: &VariantInstrument, 
    context: &MarketContext
) -> Result<(f64, f64)> {
    // Extract market data specific to this variant
}

struct VariantCalculationModel<'a> {
    instrument: &'a VariantInstrument,
    param1: f64,
    param2: f64,
}

impl<'a> CalculationModel for VariantCalculationModel<'a> {
    fn calculate_value(
        &self,
        _period_start: finstack_core::dates::Date,
        _period_end: finstack_core::dates::Date,
        t_start: f64,
        t_end: f64,
        initial_value: f64,
        context: &MarketContext,
    ) -> Result<f64> {
        // Variant-specific calculation logic
    }
}

/// Calculates the present value of the leg for {Variant} {InstrumentType}.
///
/// # Arguments
/// * `instrument` — The {variant} instrument
/// * `context` — Market context containing curves and market data
/// * `as_of` — Valuation date
///
/// # Returns
/// Present value of the leg in the instrument's currency.
pub fn pv_leg(instrument: &VariantInstrument, context: &MarketContext, as_of: Date) -> Result<Money> {
    let (param1, param2) = extract_underlying_data(instrument, context)?;
    let initial = instrument.initial_level.unwrap_or(param1);

    let params = LegParams {
        schedule: &instrument.schedule,
        notional: instrument.notional,
        curve_id: instrument.specification.curve_id.as_str(),
        additional_param: instrument.underlying.param,
        initial_value: Some(initial),
    };

    let model = VariantCalculationModel { 
        instrument, 
        param1, 
        param2 
    };
    
    EngineName::pv_leg_with_model(params, context, as_of, &model)
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finstack.io/schemas/attribution/1/attribution.schema.json",
  "title": "Finstack Attribution Specification",
  "description": "Complete specification for P&L attribution runs with instrument and market snapshots",
  "type": "object",
  "required": ["schema", "attribution"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "finstack.attribution/1",
      "description": "Schema version identifier"
    },
    "attribution": {
      "type": "object",
      "description": "The attribution specification",
      "required": ["instrument", "market_t0", "market_t1", "as_of_t0", "as_of_t1", "method"],
      "additionalProperties": false,
      "properties": {
        "instrument": {
          "type": "object",
          "description": "Instrument to attribute (tagged union with type discriminator)",
          "required": ["type", "spec"],
          "properties": {
            "type": {
              "type": "string",
              "description": "Instrument type discriminator (e.g., 'bond', 'interest_rate_swap', etc.)"
            },
            "spec": {
              "type": "object",
              "description": "Instrument-specific specification"
            }
          }
        },
        "market_t0": {
          "type": "object",
          "description": "Market context state at T₀",
          "required": ["curves", "surfaces", "prices", "series", "inflation_indices", "credit_indices", "collateral"],
          "properties": {
            "curves": {
              "type": "array",
              "description": "All curves (discount, forward, hazard, inflation, base correlation)"
            },
            "surfaces": {
              "type": "array",
              "description": "Volatility surfaces"
            },
            "prices": {
              "type": "object",
              "description": "Market scalars and prices"
            },
            "series": {
              "type": "array",
              "description": "Generic time series"
            },
            "inflation_indices": {
              "type": "array",
              "description": "Inflation indices"
            },
            "credit_indices": {
              "type": "array",
              "description": "Credit index aggregates"
            },
            "collateral": {
              "type": "object",
              "description": "Collateral CSA mappings"
            }
          }
        },
        "market_t1": {
          "type": "object",
          "description": "Market context state at T₁",
          "required": ["curves", "surfaces", "prices", "series", "inflation_indices", "credit_indices", "collateral"],
          "properties": {
            "curves": { "type": "array" },
            "surfaces": { "type": "array" },
            "prices": { "type": "object" },
            "series": { "type": "array" },
            "inflation_indices": { "type": "array" },
            "credit_indices": { "type": "array" },
            "collateral": { "type": "object" }
          }
        },
        "as_of_t0": {
          "type": "string",
          "format": "date",
          "description": "Valuation date at T₀ (YYYY-MM-DD)"
        },
        "as_of_t1": {
          "type": "string",
          "format": "date",
          "description": "Valuation date at T₁ (YYYY-MM-DD)"
        },
        "method": {
          "description": "Attribution methodology (Parallel, Waterfall, or MetricsBased)",
          "oneOf": [
            { "const": "Parallel", "description": "Parallel independent factor isolation" },
            { "const": "MetricsBased", "description": "Linear approximation using metrics" },
            {
              "type": "object",
              "description": "Waterfall sequential attribution with factor order",
              "required": ["Waterfall"],
              "properties": {
                "Waterfall": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "Carry", "RatesCurves", "CreditCurves", "InflationCurves",
                      "Correlations", "Fx", "Volatility", "ModelParameters", "MarketScalars"
                    ]
                  }
                }
              }
            }
          ]
        },
        "config": {
          "type": "object",
          "description": "Optional attribution configuration overrides",
          "additionalProperties": false,
          "properties": {
            "tolerance_abs": {
              "type": "number",
              "description": "Absolute tolerance for residual validation"
            },
            "tolerance_pct": {
              "type": "number",
              "description": "Percentage tolerance for residual validation"
            },
            "metrics": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Metrics to compute for metrics-based attribution"
            }
          }
        }
      }
    }
  }
}


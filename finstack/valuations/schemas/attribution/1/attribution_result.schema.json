{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finstack.io/schemas/attribution/1/attribution_result.schema.json",
  "title": "Finstack Attribution Result",
  "description": "Complete result of a P&L attribution run including factor decomposition and metadata",
  "type": "object",
  "required": ["schema", "result"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "finstack.attribution/1",
      "description": "Schema version identifier"
    },
    "result": {
      "type": "object",
      "required": ["attribution", "results_meta"],
      "additionalProperties": false,
      "properties": {
        "attribution": {
          "type": "object",
          "description": "P&L attribution with factor decomposition",
          "required": [
            "total_pnl", "carry", "rates_curves_pnl", "credit_curves_pnl",
            "inflation_curves_pnl", "correlations_pnl", "fx_pnl", "vol_pnl",
            "model_params_pnl", "market_scalars_pnl", "residual", "meta"
          ],
          "properties": {
            "total_pnl": {
              "type": "object",
              "description": "Total P&L (val_t1 - val_t0)",
              "required": ["amount", "currency"],
              "properties": {
                "amount": { "type": "string" },
                "currency": { "type": "string", "pattern": "^[A-Z]{3}$" }
              }
            },
            "carry": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "rates_curves_pnl": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "credit_curves_pnl": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "inflation_curves_pnl": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "correlations_pnl": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "fx_pnl": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "vol_pnl": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "model_params_pnl": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "market_scalars_pnl": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "residual": { "$ref": "#/properties/result/properties/attribution/properties/total_pnl" },
            "rates_detail": {
              "type": "object",
              "description": "Optional detailed rates curves attribution"
            },
            "credit_detail": {
              "type": "object",
              "description": "Optional detailed credit curves attribution"
            },
            "inflation_detail": {
              "type": "object",
              "description": "Optional detailed inflation curves attribution"
            },
            "correlations_detail": {
              "type": "object",
              "description": "Optional detailed correlations attribution"
            },
            "fx_detail": {
              "type": "object",
              "description": "Optional detailed FX attribution"
            },
            "vol_detail": {
              "type": "object",
              "description": "Optional detailed volatility attribution"
            },
            "model_params_detail": {
              "type": "object",
              "description": "Optional detailed model parameters attribution"
            },
            "scalars_detail": {
              "type": "object",
              "description": "Optional detailed market scalars attribution"
            },
            "credit_factor_detail": {
              "description": "Optional credit-factor-hierarchy decomposition of credit_curves_pnl (PR-9). Populated only when AttributionSpec.credit_factor_model was supplied. Additive: absent on pre-feature payloads.",
              "type": "object",
              "required": ["model_id", "generic_pnl", "levels", "adder_pnl_total"],
              "properties": {
                "model_id": {
                  "type": "string",
                  "description": "Deterministic traceability ID for the calibrated model."
                },
                "generic_pnl": {
                  "$ref": "#/$defs/Money",
                  "description": "P&L attributed to the generic (PC) credit factor."
                },
                "levels": {
                  "type": "array",
                  "description": "One entry per hierarchy level in spec order.",
                  "items": { "$ref": "#/$defs/LevelPnl" }
                },
                "adder_pnl_total": {
                  "$ref": "#/$defs/Money",
                  "description": "Total adder P&L across all issuers."
                },
                "adder_pnl_by_issuer": {
                  "type": "object",
                  "description": "Optional per-issuer adder breakdown (gated by CreditFactorDetailOptions.include_per_issuer_adder).",
                  "additionalProperties": { "$ref": "#/$defs/Money" }
                }
              }
            },
            "credit_carry_decomposition": {
              "description": "Optional credit-factor-hierarchy decomposition of carry (PR-9). Populated only when AttributionSpec.credit_factor_model was supplied. Additive: absent on pre-feature payloads.",
              "type": "object",
              "required": ["model_id", "rates_carry_total", "credit_carry_total", "credit_by_level"],
              "properties": {
                "model_id": {
                  "type": "string",
                  "description": "Deterministic traceability ID matching CreditFactorAttribution.model_id."
                },
                "rates_carry_total": {
                  "$ref": "#/$defs/Money",
                  "description": "Sum of rates components across split source lines, minus funding cost."
                },
                "credit_carry_total": {
                  "$ref": "#/$defs/Money",
                  "description": "Sum of credit components across split source lines."
                },
                "credit_by_level": {
                  "type": "object",
                  "required": ["generic", "levels", "adder_total"],
                  "properties": {
                    "generic": { "$ref": "#/$defs/Money", "description": "Generic (PC) factor contribution to credit carry." },
                    "levels": {
                      "type": "array",
                      "description": "One entry per hierarchy level in spec order.",
                      "items": { "$ref": "#/$defs/LevelCarry" }
                    },
                    "adder_total": { "$ref": "#/$defs/Money", "description": "Sum of issuer-specific adder carry contributions." },
                    "adder_by_issuer": {
                      "type": "object",
                      "description": "Optional per-issuer adder breakdown.",
                      "additionalProperties": { "$ref": "#/$defs/Money" }
                    }
                  }
                }
              }
            },
            "carry_detail": {
              "description": "Optional detailed carry decomposition. coupon_income and roll_down accept either legacy Money shape {amount, currency} or new SourceLine shape {total, rates_part?, credit_part?}.",
              "type": "object",
              "required": ["total"],
              "properties": {
                "total": { "$ref": "#/$defs/Money" },
                "coupon_income": { "$ref": "#/$defs/SourceLineOrMoney" },
                "pull_to_par": { "$ref": "#/$defs/Money" },
                "roll_down": { "$ref": "#/$defs/SourceLineOrMoney" },
                "funding_cost": { "$ref": "#/$defs/Money" },
                "theta": { "$ref": "#/$defs/Money" }
              }
            },
            "meta": {
              "type": "object",
              "description": "Attribution metadata",
              "required": [
                "method", "t0", "t1", "instrument_id", "num_repricings",
                "tolerance_abs", "tolerance_pct", "residual_pct", "rounding"
              ],
              "properties": {
                "method": {
                  "description": "Attribution method used"
                },
                "t0": { "type": "string", "format": "date" },
                "t1": { "type": "string", "format": "date" },
                "instrument_id": { "type": "string" },
                "num_repricings": { "type": "integer" },
                "tolerance_abs": { "type": "number" },
                "tolerance_pct": { "type": "number" },
                "residual_pct": { "type": "number" },
                "rounding": { "type": "object" },
                "fx_policy": { "type": "object" },
                "notes": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        },
        "results_meta": {
          "type": "object",
          "description": "Results metadata (timestamp, version, rounding context)"
        }
      }
    }
  },
  "$defs": {
    "Money": {
      "type": "object",
      "description": "A signed monetary amount with currency.",
      "required": ["amount", "currency"],
      "properties": {
        "amount": { "type": "string", "description": "Decimal string representation of the amount." },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$", "description": "ISO 4217 currency code." }
      }
    },
    "SourceLine": {
      "type": "object",
      "description": "New SourceLine shape with optional rates/credit split.",
      "required": ["total"],
      "properties": {
        "total": { "$ref": "#/$defs/Money", "description": "Total signed amount (always populated)." },
        "rates_part": { "$ref": "#/$defs/Money", "description": "Rates-only contribution (populated when a credit factor model drove the split)." },
        "credit_part": { "$ref": "#/$defs/Money", "description": "Credit-only contribution (populated when a credit factor model drove the split)." }
      }
    },
    "SourceLineOrMoney": {
      "description": "coupon_income and roll_down: accepts legacy Money shape {amount, currency} or new SourceLine shape {total, rates_part?, credit_part?}. Custom Deserialize in Rust disambiguates by presence of the 'total' key.",
      "oneOf": [
        { "$ref": "#/$defs/Money" },
        { "$ref": "#/$defs/SourceLine" }
      ]
    },
    "LevelPnl": {
      "type": "object",
      "description": "P&L contribution from a single hierarchy level.",
      "required": ["level_name", "total"],
      "properties": {
        "level_name": { "type": "string", "description": "Human-readable level name (e.g. rating, region, sector)." },
        "total": { "$ref": "#/$defs/Money", "description": "Aggregate P&L for this level across all buckets." },
        "by_bucket": {
          "type": "object",
          "description": "Optional per-bucket breakdown keyed by dotted bucket path (e.g. IG.EU.FIN).",
          "additionalProperties": { "$ref": "#/$defs/Money" }
        }
      }
    },
    "LevelCarry": {
      "type": "object",
      "description": "Carry contribution from a single hierarchy level.",
      "required": ["level_name", "total"],
      "properties": {
        "level_name": { "type": "string", "description": "Human-readable level name." },
        "total": { "$ref": "#/$defs/Money", "description": "Aggregate carry for this level across all buckets." },
        "by_bucket": {
          "type": "object",
          "description": "Optional per-bucket breakdown keyed by dotted bucket path.",
          "additionalProperties": { "$ref": "#/$defs/Money" }
        }
      }
    }
  }
}

            "tree_steps": null,
            "tree_volatility": null,
            "use_gobet_miri": false,
            "call_friction_cents": null,
            "mean_reversion": null
          },
          "attributes": {
            "tags": [
              "fx"
            ],
            "meta": {
              "pair": "EURUSD"
            }
          }
        }
      }
    }
  ],
  "properties": {
    "instrument": {
      "description": "The FX Forward instrument definition",
      "type": "object"
    },
    "schema": {

{
  "$id": "https://finstack.dev/schemas/instrument/1/fx/fx_touch_option.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "FX touch/no-touch barrier option with configurable barrier direction and payout timing",
  "examples": [
    {
      "schema": "finstack.instrument/1",
      "instrument": {
        "type": "fx_touch_option",
        "spec": {
          "id": "FXTOUCH-EURUSD-OT",
          "base_currency": "EUR",
          "quote_currency": "USD",
          "barrier_level": 1.05,
          "touch_type": "one_touch",
          "barrier_direction": "down",
          "payout_amount": {
            "amount": "1000000",
            "currency": "USD"
          },
          "payout_timing": "at_expiry",
          "expiry": "2024-06-21",
          "day_count": "Act365F",
          "domestic_discount_curve_id": "USD-OIS",
          "foreign_discount_curve_id": "EUR-OIS",
          "vol_surface_id": "EURUSD-VOL",
          "pricing_overrides": {
            "quoted_clean_price": null,
            "implied_volatility": null,
            "quoted_spread_bp": null,
            "upfront_payment": null,
            "rho_bump_decimal": null,
            "vega_bump_decimal": null,
            "ytm_bump_decimal": null,
            "spot_bump_pct": null,
            "vol_bump_pct": null,
            "rate_bump_bp": null,
            "credit_spread_bump_bp": null,
            "adaptive_bumps": false,
            "mc_seed_scenario": null,
            "theta_period": null,
            "vol_surface_extrapolation": "error",
            "tree_steps": null,
            "tree_volatility": null,
            "use_gobet_miri": false,
            "call_friction_cents": null,
            "mean_reversion": null
          },
          "attributes": {}
        }
      }
    }
  ],
  "properties": {
    "instrument": {
      "description": "The FX Touch Option instrument definition",
      "type": "object"
    },
    "schema": {
      "const": "finstack.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "FX Touch Option",
  "type": "object"
}

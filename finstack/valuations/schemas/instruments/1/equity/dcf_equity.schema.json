{
  "$id": "https://finstack.dev/schemas/instrument/1/equity/dcf_equity.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Discounted Cash Flow instrument for corporate equity valuation",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {
            "meta": {},
            "tags": []
          },
          "currency": "USD",
          "discount_curve_id": "USD-OIS",
          "flows": [
            ["2026-01-01", 100.0],
            ["2027-01-01", 110.0],
            ["2028-01-01", 121.0]
          ],
          "id": "DCF-EXAMPLE",
          "net_debt": 500000.0,
          "terminal_value": {
            "type": "gordon_growth",
            "growth_rate": 0.02
          },
          "valuation_date": "2025-01-01",
          "wacc": 0.10
        },
        "type": "dcf_equity"
      },
      "schema": "finstack.instrument/1"
    },
    {
      "instrument": {
        "spec": {
          "attributes": {
            "meta": {},
            "tags": ["private"]
          },
          "currency": "USD",
          "discount_curve_id": "USD-DISCOUNT",
          "flows": [
            ["2026-01-01", 5000000.0],
            ["2027-01-01", 6000000.0],
            ["2028-01-01", 7000000.0],
            ["2029-01-01", 7500000.0],
            ["2030-01-01", 8000000.0]
          ],
          "id": "DCF-PRIVATE-CO",
          "net_debt": 0.0,
          "terminal_value": {
            "type": "exit_multiple",
            "terminal_metric": 12000000.0,
            "multiple": 8.0
          },
          "valuation_date": "2025-01-01",
          "wacc": 0.12,
          "mid_year_convention": true,
          "equity_bridge": {
            "total_debt": 25000000.0,
            "cash": 5000000.0,
            "preferred_equity": 10000000.0,
            "minority_interest": 0.0,
            "non_operating_assets": 2000000.0
          },
          "shares_outstanding": 1000000.0,
          "valuation_discounts": {
            "dlom": 0.25,
            "dloc": 0.15
          }
        },
        "type": "dcf_equity"
      },
      "schema": "finstack.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "description": "The DCF Equity instrument definition",
      "type": "object",
      "properties": {
        "type": {
          "const": "dcf_equity",
          "type": "string"
        },
        "spec": {
          "type": "object",
          "required": ["id", "currency", "flows", "wacc", "terminal_value", "net_debt", "valuation_date", "discount_curve_id"],
          "properties": {
            "id": { "type": "string", "description": "Unique instrument identifier" },
            "currency": { "type": "string", "description": "ISO 4217 currency code" },
            "flows": {
              "type": "array",
              "description": "Explicit period free cash flows as [date, amount] pairs",
              "items": {
                "type": "array",
                "items": [{ "type": "string", "format": "date" }, { "type": "number" }],
                "minItems": 2,
                "maxItems": 2
              }
            },
            "wacc": { "type": "number", "description": "Weighted Average Cost of Capital (decimal)" },
            "terminal_value": {
              "description": "Terminal value specification",
              "oneOf": [
                {
                  "type": "object",
                  "required": ["type", "growth_rate"],
                  "properties": {
                    "type": { "const": "gordon_growth" },
                    "growth_rate": { "type": "number", "description": "Perpetual growth rate (decimal)" }
                  },
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "required": ["type", "terminal_metric", "multiple"],
                  "properties": {
                    "type": { "const": "exit_multiple" },
                    "terminal_metric": { "type": "number", "description": "Terminal metric value (e.g., EBITDA)" },
                    "multiple": { "type": "number", "description": "Exit multiple (e.g., 10.0x)" }
                  },
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "required": ["type", "high_growth_rate", "stable_growth_rate", "half_life_years"],
                  "properties": {
                    "type": { "const": "h_model" },
                    "high_growth_rate": { "type": "number", "description": "Initial high growth rate (decimal)" },
                    "stable_growth_rate": { "type": "number", "description": "Long-run stable growth rate (decimal)" },
                    "half_life_years": { "type": "number", "description": "Half-life of growth fade (years)" }
                  },
                  "additionalProperties": false
                }
              ]
            },
            "net_debt": { "type": "number", "description": "Net debt (debt - cash). Ignored when equity_bridge is set." },
            "valuation_date": { "type": "string", "format": "date", "description": "As-of date for DCF" },
            "discount_curve_id": { "type": "string", "description": "Discount curve identifier" },
            "mid_year_convention": { "type": "boolean", "default": false, "description": "Mid-year discounting (default: false)" },
            "equity_bridge": {
              "type": "object",
              "description": "Structured EV-to-equity bridge (overrides net_debt when present)",
              "properties": {
                "total_debt": { "type": "number", "default": 0.0 },
                "cash": { "type": "number", "default": 0.0 },
                "preferred_equity": { "type": "number", "default": 0.0 },
                "minority_interest": { "type": "number", "default": 0.0 },
                "non_operating_assets": { "type": "number", "default": 0.0 },
                "other_adjustments": {
                  "type": "array",
                  "items": {
                    "type": "array",
                    "items": [{ "type": "string" }, { "type": "number" }],
                    "minItems": 2,
                    "maxItems": 2
                  }
                }
              }
            },
            "shares_outstanding": { "type": "number", "description": "Basic shares outstanding" },
            "dilution_securities": {
              "type": "array",
              "description": "Dilutive securities for treasury stock method",
              "items": {
                "type": "object",
                "required": ["name", "quantity", "exercise_price"],
                "properties": {
                  "name": { "type": "string" },
                  "quantity": { "type": "number" },
                  "exercise_price": { "type": "number" }
                }
              }
            },
            "valuation_discounts": {
              "type": "object",
              "description": "Private company valuation discounts",
              "properties": {
                "dlom": { "type": "number", "description": "Discount for Lack of Marketability (0.0-1.0)" },
                "dloc": { "type": "number", "description": "Discount for Lack of Control (0.0-1.0)" },
                "other_discount": { "type": "number", "description": "Additional discount (0.0-1.0)" }
              }
            },
            "attributes": {
              "type": "object",
              "description": "Attributes for tagging and scenarios"
            }
          }
        }
      }
    },
    "schema": {
      "const": "finstack.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "DCF Equity",
  "type": "object"
}

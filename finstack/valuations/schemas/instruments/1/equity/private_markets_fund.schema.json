{
  "$id": "https://finstack.dev/schemas/instrument/1/equity/private_markets_fund.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "description": "Fund with waterfall distributions and events",
  "examples": [
    {
      "schema": "finstack.instrument/1",
      "instrument": {
        "type": "private_markets_fund",
        "spec": {
          "id": "PMF-EXAMPLE",
          "currency": "USD",
          "waterfall_spec": {
            "style": "european",
            "tranches": [
              "return_of_capital",
              {
                "preferred_irr": {
                  "irr": 0.08
                }
              },
              {
                "catch_up": {
                  "gp_share": 0.5
                }
              },
              {
                "promote_tier": {
                  "hurdle": {
                    "irr": {
                      "rate": 0.12
                    }
                  },
                  "lp_share": 0.8,
                  "gp_share": 0.2
                }
              }
            ],
            "clawback": null,
            "irr_basis": "Act365F",
            "catchup_mode": "full"
          },
          "events": [
            {
              "date": "2024-01-15",
              "amount": {
                "amount": "5000000",
                "currency": "USD"
              },
              "kind": "contribution",
              "deal_id": null
            },
            {
              "date": "2024-06-15",
              "amount": {
                "amount": "2000000",
                "currency": "USD"
              },
              "kind": "contribution",
              "deal_id": null
            },
            {
              "date": "2026-03-01",
              "amount": {
                "amount": "4000000",
                "currency": "USD"
              },
              "kind": "proceeds",
              "deal_id": "DEAL-1"
            },
            {
              "date": "2027-01-01",
              "amount": {
                "amount": "4000000",
                "currency": "USD"
              },
              "kind": "distribution",
              "deal_id": null

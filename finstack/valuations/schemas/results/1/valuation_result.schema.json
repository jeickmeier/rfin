{
  "$defs": {
    "CovenantReport": {
      "description": "Covenant check result.",
      "properties": {
        "actual_value": {
          "description": "Actual value of the metric",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "covenant_id": {
          "description": "Stable machine-readable identifier (from\n[`crate::covenants::CovenantType::covenant_id`]).",
          "type": [
            "string",
            "null"
          ]
        },
        "covenant_type": {
          "description": "Type of covenant being checked",
          "type": "string"
        },
        "details": {
          "description": "Details or explanation",
          "type": [
            "string",
            "null"
          ]
        },
        "headroom": {
          "description": "Cushion relative to threshold (positive => passing buffer)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "passed": {
          "description": "Whether the covenant passed",
          "type": "boolean"
        },
        "threshold": {
          "description": "Required threshold",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        }
      },
      "required": [
        "covenant_type",
        "passed"
      ],
      "type": "object"
    },
    "CreditDerivativeValuationDetails": {
      "description": "Metadata for CDS-family valuation paths.",
      "properties": {
        "integration_method": {
          "description": "CDS integration method actually used, when applicable.",
          "type": [
            "string",
            "null"
          ]
        },
        "model_key": {
          "description": "Registered model key used by the pricer.",
          "type": "string"
        }
      },
      "required": [
        "model_key"
      ],
      "type": "object"
    },

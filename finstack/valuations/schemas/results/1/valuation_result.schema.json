    "ExplanationTrace": {
      "description": "Container for detailed execution traces of financial computations.\n\nTraces are organized by type (calibration, pricing, waterfall) and contain\na sequence of domain-specific entries. Traces can be serialized to JSON for\ninspection, debugging, or audit purposes.\n\nMutation is intentionally single-threaded through `&mut self`. If multiple\nworkers need to append to one trace, wrap it in external synchronization and\nkeep ordering semantics explicit at the call site.",
      "properties": {
        "entries": {
          "description": "Sequence of trace entries",
          "items": {
            "$ref": "#/$defs/TraceEntry"
          },
          "type": "array"
        },
        "truncated": {
          "description": "Whether the trace was truncated due to size limits",
          "type": [
            "boolean",
            "null"
          ]
        },
        "type": {
          "description": "Type of trace (e.g., \"calibration\", \"pricing\", \"waterfall\")",
          "type": "string"
        }
      },
      "required": [
        "type",
        "entries"
      ],
      "type": "object"
    },
    "Money": {
      "additionalProperties": false,
      "description": "Currency-tagged monetary amount with safe arithmetic.\n\nValues are stored using a fixed-point representation derived from ISO 4217\ndecimal places.\n\nWhen you need configurable rounding during ingestion, use\n[`Money::new_with_config`].\n\n# Examples\n```rust\nuse finstack_core::money::Money;\nuse finstack_core::currency::Currency;\n\nlet notional = Money::new(1_000_000.0, Currency::EUR);\nassert_eq!(notional.currency(), Currency::EUR);\nassert_eq!(notional.amount(), 1_000_000.0);\n```",
      "properties": {
        "amount": {
          "pattern": "^-?\\d+(\\.\\d+)?([eE]\\d+)?$",
          "type": [
            "string",
            "number"
          ]
        },
        "currency": {
          "$ref": "#/$defs/Currency"
        }
      },
      "required": [
        "amount",
        "currency"
      ],
      "type": "object"
    },
    "NumericMode": {
      "description": "Numeric engine mode compiled into the crate.\n\nCurrently single-variant (F64); exists as `#[non_exhaustive]` for forward-compatible extension.",
      "oneOf": [
        {
          "const": "F64",
          "description": "Floating-point f64 engine.",
          "type": "string"
        }
      ]
    },
    "ResultsMeta": {
      "description": "Metadata bundle that accompanies valuation outputs.\n\nThe metadata is intentionally small so it can be attached to reports and\ndownstream data stores for reproducibility and audit trails.\n\n# Examples\n```rust\nuse finstack_core::config::{results_meta, FinstackConfig, NumericMode};\n\nlet meta = results_meta(&FinstackConfig::default());\nassert_eq!(meta.numeric_mode, NumericMode::F64);\nassert!(meta.timestamp.is_none()); // deterministic by default\n```",
      "properties": {
        "fx_policy_applied": {
          "default": null,
          "description": "Optional FX policy applied by the computing layer (human-readable key).",
          "type": [
            "string",
            "null"
          ]
        },
        "numeric_mode": {
          "$ref": "#/$defs/NumericMode",
          "description": "Numeric engine mode used to produce the results."
        },
        "rounding": {
          "$ref": "#/$defs/RoundingContext",
          "description": "Rounding context snapshot applied to IO boundaries."
        },
        "timestamp": {
          "description": "Timestamp when result was computed (ISO 8601 format).\nUseful for audit trails and reproducibility.",
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "description": "Finstack library version used to produce the result.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "numeric_mode",
        "rounding"
      ],
      "type": "object"
    },
    "RoundingContext": {
      "description": "Snapshot of active rounding settings used for result stamping.\n\nInstances are typically produced via [`rounding_context_from`] and persisted\nalongside valuation results.",
      "properties": {
        "ingest_scale_by_ccy": {
          "additionalProperties": {
            "format": "uint32",
            "minimum": 0,
            "type": "integer"
          },
          "description": "Ingest scale map snapshot by currency code.",
          "type": "object"
        },
        "mode": {
          "$ref": "#/$defs/RoundingMode",
          "description": "Active rounding mode."
        },
        "output_scale_by_ccy": {
          "additionalProperties": {
            "format": "uint32",
            "minimum": 0,
            "type": "integer"
          },
          "description": "Output scale map snapshot by currency code.",
          "type": "object"
        },
        "tolerances": {
          "$ref": "#/$defs/ToleranceConfig",
          "default": {
            "generic_epsilon": 1e-10,
            "rate_epsilon": 1e-12
          },
          "description": "Tolerance settings snapshot for floating-point comparisons."
        },
        "version": {
          "description": "Schema version for forward compatibility.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "mode",
        "ingest_scale_by_ccy",
        "output_scale_by_ccy",
        "version"
      ],
      "type": "object"
    },
    "RoundingMode": {
      "description": "Rounding modes supported by the library.\n\nThe variants mirror the most common conventions found in pricing engines.\n\n# Examples\n```rust\nuse finstack_core::config::{FinstackConfig, RoundingMode};\n\nlet mut cfg = FinstackConfig::default();\ncfg.rounding.mode = RoundingMode::TowardZero;\nassert!(matches!(cfg.rounding.mode, RoundingMode::TowardZero));\n```",
      "oneOf": [
        {
          "const": "Bankers",
          "description": "Banker's rounding (ties to even).",
          "type": "string"
        },
        {
          "const": "AwayFromZero",
          "description": "Round halves away from zero.",
          "type": "string"
        },
        {
          "const": "TowardZero",
          "description": "Round toward zero (truncate).",
          "type": "string"
        },
        {
          "const": "Floor",
          "description": "Round toward negative infinity.",
          "type": "string"
        },
        {
          "const": "Ceil",
          "description": "Round toward positive infinity.",
          "type": "string"
        }
      ]
    },
    "StochasticPricingResult": {
      "description": "Stochastic pricing result for a structured credit deal.",
      "properties": {
        "clean_price": {
          "description": "Clean price (as percentage of notional)",
          "format": "double",
          "type": "number"
        },
        "dirty_price": {
          "description": "Dirty price (including accrued interest)",
          "format": "double",
          "type": "number"
        },
        "es_confidence": {
          "description": "ES confidence level used",
          "format": "double",
          "type": "number"
        },
        "expected_loss": {
          "$ref": "#/$defs/Money",
          "description": "Expected loss (probability-weighted average loss)"
        },
        "expected_shortfall": {
          "$ref": "#/$defs/Money",
          "description": "Expected shortfall (tail risk metric)"
        },
        "npv": {
          "$ref": "#/$defs/Money",
          "description": "Net present value of the deal"
        },
        "num_paths": {
          "description": "Number of scenario paths",
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        },
        "pricing_mode": {
          "description": "Pricing mode used",
          "type": "string"
        },
        "pv_confidence_interval": {
          "description": "95% confidence interval for the mean PV",
          "maxItems": 2,
          "minItems": 2,
          "prefixItems": [
            {
              "format": "double",
              "type": "number"
            },
            {
              "format": "double",
              "type": "number"
            }
          ],
          "type": "array"
        },
        "pv_std_error": {
          "description": "Standard error of the mean PV estimate",
          "format": "double",
          "type": "number"
        },
        "tranche_results": {
          "description": "Tranche-level results",
          "items": {
            "$ref": "#/$defs/TranchePricingResult"
          },
          "type": "array"
        },
        "unexpected_loss": {
          "$ref": "#/$defs/Money",
          "description": "Unexpected loss (loss standard deviation)"
        }
      },
      "required": [
        "npv",
        "clean_price",
        "dirty_price",
        "expected_loss",
        "unexpected_loss",
        "expected_shortfall",
        "es_confidence",
        "pv_std_error",
        "pv_confidence_interval",
        "num_paths",
        "pricing_mode",
        "tranche_results"
      ],
      "type": "object"
    },
    "ToleranceConfig": {
      "description": "Numerical tolerance configuration for floating-point comparisons.\n\nProvides configurable epsilon values for zero-checks in rate calculations\nand generic floating-point comparisons. These defaults are chosen to balance\nnumerical stability with practical precision requirements.\n\n# Examples\n```rust\nuse finstack_core::config::ToleranceConfig;\n\nlet mut tol = ToleranceConfig::default();\nassert_eq!(tol.rate_epsilon, 1e-12);\n\n// Customize for stricter rate comparisons\ntol.rate_epsilon = 1e-14;\n```",
      "properties": {
        "generic_epsilon": {
          "default": 1e-10,
          "description": "Epsilon for generic floating-point comparisons (default: 1e-10).\n\nUsed for general numerical comparisons where higher tolerance is acceptable.",
          "format": "double",
          "type": "number"
        },
        "rate_epsilon": {
          "default": 1e-12,
          "description": "Epsilon for rate comparisons (default: 1e-12).\n\nUsed when comparing interest rates, yields, and other small ratios.",
          "format": "double",
          "type": "number"
        }
      },
      "type": "object"
    },
    "TraceEntry": {
      "description": "Domain-specific trace entry types.\n\nEach variant captures relevant details for different types of computations:\n- Calibration: iteration details, convergence status\n- Pricing: cashflow-level PV breakdowns\n- Waterfall: step-by-step payment allocations",
      "oneOf": [
        {
          "description": "Calibration solver iteration details",
          "properties": {
            "converged": {
              "description": "Whether convergence was achieved",
              "type": "boolean"
            },
            "iteration": {
              "description": "Iteration number (0-based)",
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "kind": {
              "const": "calibration_iteration",
              "type": "string"
            },
            "knots_updated": {
              "description": "Knot points that were updated",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "residual": {
              "description": "Objective function residual",
              "format": "double",
              "type": "number"
            }
          },
          "required": [
            "kind",
            "iteration",
            "residual",
            "knots_updated",
            "converged"
          ],
          "type": "object"
        },
        {
          "description": "Cashflow present value breakdown",
          "properties": {
            "cashflow_amount": {
              "description": "Cashflow amount (stored as f64 for JSON simplicity)",
              "format": "double",
              "type": "number"
            },
            "cashflow_currency": {
              "description": "Cashflow currency",
              "type": "string"
            },
            "curve_id": {
              "description": "Discount curve ID used",
              "type": "string"
            },
            "date": {
              "description": "Cashflow payment date (ISO8601)",
              "type": "string"
            },
            "discount_factor": {
              "description": "Discount factor applied",
              "format": "double",
              "type": "number"
            },
            "kind": {
              "const": "cashflow_pv",
              "type": "string"
            },
            "pv_amount": {
              "description": "Present value of this cashflow",
              "format": "double",
              "type": "number"
            },
            "pv_currency": {
              "description": "PV currency",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "date",
            "cashflow_amount",
            "cashflow_currency",
            "discount_factor",
            "pv_amount",
            "pv_currency",
            "curve_id"
          ],
          "type": "object"
        },
        {
          "description": "Structured credit waterfall step",
          "properties": {
            "cash_in_amount": {
              "description": "Cash inflow amount",
              "format": "double",
              "type": "number"
            },
            "cash_in_currency": {
              "description": "Cash inflow currency",
              "type": "string"
            },
            "cash_out_amount": {
              "description": "Cash outflow amount",
              "format": "double",
              "type": "number"
            },
            "cash_out_currency": {
              "description": "Cash outflow currency",
              "type": "string"
            },
            "kind": {
              "const": "waterfall_step",
              "type": "string"
            },
            "period": {
              "description": "Period index",
              "format": "uint",
              "minimum": 0,
              "type": "integer"
            },
            "shortfall_amount": {
              "description": "Shortfall amount if any",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "shortfall_currency": {
              "description": "Shortfall currency",
              "type": [
                "string",
                "null"
              ]
            },
            "step_name": {
              "description": "Step name/description",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "period",
            "step_name",
            "cash_in_amount",
            "cash_in_currency",
            "cash_out_amount",
            "cash_out_currency"
          ],
          "type": "object"
        },
        {
          "description": "Generic computation step (extensible)",
          "properties": {

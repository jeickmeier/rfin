  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Valuation result envelope with PV, metrics, metadata, covenants, and optional explanation trace.",
  "properties": {
    "as_of": {
      "description": "Valuation date (T+0) for the calculation.",
      "type": "string"
    },
    "covenants": {
      "additionalProperties": {
        "$ref": "#/$defs/CovenantReport"
      },
      "description": "Covenant compliance results for structured products.\n\nPresent only for instruments with covenants (loans, structured credit).\nEach covenant is keyed by its identifier with pass/fail status and details.",
      "type": [
        "object",
        "null"
      ]
    },
    "details": {
      "anyOf": [
        {
          "$ref": "#/$defs/ValuationDetails"
        },
        {
          "type": "null"
        }
      ],
      "description": "Optional rich model-specific pricing detail."
    },
    "explanation": {
      "anyOf": [
        {
          "$ref": "#/$defs/ExplanationTrace"
        },
        {
          "type": "null"
        }
      ],
      "description": "Optional computation explanation trace.\n\nEnabled via `ExplainOpts` in configuration. Provides step-by-step\ntrace of calculations for debugging and auditability."
    },
    "instrument_id": {
      "description": "Unique identifier for the priced instrument.",
      "type": "string"
    },
    "measures": {
      "additionalProperties": {
        "format": "double",
        "type": "number"
      },
      "description": "Computed risk measures and financial metrics.\n\nContains **derived risk metrics** such as DV01, Delta, Vega, etc.\nThe present value (PV) is **not** included here - it is available\nin the `value` field above.\n\nKeys are strongly-typed metric IDs (serialized as strings such as\n\"ytm\", \"dv01\", \"delta\"). Use `MetricId` helpers for consistent lookups.\n\n# Interpretation\n\nEntries in this map are heterogeneous by design:\n- some are currency amounts (`jump_to_default`)\n- some are currency-per-bump sensitivities (`dv01`, `vega`, `rho`)\n- some are decimal rates or probabilities (`ytm`, `default_probability`)\n- some are ratios or counts (`tvpi_lp`, `constituent_count`)\n\nAlways interpret a measure together with its [`MetricId`] contract.",
      "type": "object"
    },
    "meta": {
      "$ref": "#/$defs/ResultsMeta",
      "description": "Calculation metadata and policy stamps.\n\nContains:\n- Numeric mode (Decimal vs f64)\n- Rounding context and precision\n- FX policy for cross-currency calculations\n- Calculation timing information"
    },
    "schema_version": {
      "default": 1,
      "description": "Wire-format schema version (see `VALUATION_RESULT_SCHEMA_VERSION`).\n\nWritten into every serialized payload so downstream consumers can\ndetect schema mismatches when reading persisted results. Defaults to\nthe current version on deserialization of pre-versioning payloads.",
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "value": {
      "$ref": "#/$defs/Money",
      "description": "Present value in the instrument's native currency.\n\nThis is the primary pricing output and is **always available** regardless\nof which metrics are requested. The PV is **not** included in the `measures`\nmap - it is provided here as a `Money` type with full currency information.\n\nFor cross-currency instruments, this may be in a different currency than\nthe base calculation currency.\n\n# Example\n```rust\n# use finstack_valuations::results::ValuationResult;\n# use finstack_core::currency::Currency;\n# use finstack_core::money::Money;\n# use finstack_core::dates::create_date;\n# use time::Month;\n# fn main() -> Result<(), Box<dyn std::error::Error>> {\n# let as_of = create_date(2025, Month::January, 15)?;\n# let pv = Money::new(1_000_000.0, Currency::USD);\n# let result = ValuationResult::stamped(\"BOND-001\", as_of, pv);\n// PV is always in result.value, not in measures\nlet pv_money = result.value;  // Money type\nlet pv_amount = result.value.amount();  // f64 value\nlet currency = result.value.currency();  // Currency type\n# Ok(())\n# }\n```"
    }
  },
  "required": [
    "instrument_id",
    "as_of",
    "value",
    "measures",
    "meta"
  ],
  "title": "ValuationResult",
  "type": "object"
}

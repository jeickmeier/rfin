{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finstack.io/schemas/factor_model/1/credit_calibration_config.schema.json",
  "title": "CreditCalibrationConfig",
  "description": "Configuration for the credit factor calibrator. Canonical Rust type: finstack_valuations::factor_model::CreditCalibrationConfig. Note: this type is not serialized into the output artifact; it is the calibration-time input configuration.",
  "type": "object",
  "required": [
    "policy",
    "hierarchy",
    "min_bucket_size_per_level",
    "vol_model",
    "covariance_strategy",
    "beta_shrinkage",
    "use_returns_or_levels",
    "annualization_factor"
  ],
  "additionalProperties": false,
  "properties": {
    "policy": {
      "$ref": "#/$defs/IssuerBetaPolicy"
    },
    "hierarchy": {
      "$ref": "#/$defs/CreditHierarchySpec"
    },
    "min_bucket_size_per_level": {
      "$ref": "#/$defs/BucketSizeThresholds"
    },
    "vol_model": {
      "$ref": "#/$defs/VolModelChoice"
    },
    "covariance_strategy": {
      "$ref": "#/$defs/CovarianceStrategy"
    },
    "beta_shrinkage": {
      "$ref": "#/$defs/BetaShrinkage"
    },
    "use_returns_or_levels": {
      "$ref": "#/$defs/PanelSpace"
    },
    "annualization_factor": {
      "type": "number",
      "description": "Annualization factor for sample variance. Default 12.0 (monthly data).",
      "default": 12.0,
      "exclusiveMinimum": 0
    }
  },
  "$defs": {
    "HierarchyDimension": {
      "title": "HierarchyDimension",
      "description": "A single level in the credit factor hierarchy.",
      "oneOf": [
        { "const": "rating", "description": "Credit rating bucket (e.g. IG, HY, NR)." },
        { "const": "region", "description": "Geographic region (e.g. EU, NA, APAC)." },
        { "const": "sector", "description": "Industry sector (e.g. FIN, ENERGY, TECH)." },
        {
          "type": "object",
          "required": ["custom"],
          "properties": {
            "custom": { "type": "string", "description": "User-defined dimension key." }
          }
        }
      ]
    },
    "CreditHierarchySpec": {
      "type": "object",
      "title": "CreditHierarchySpec",
      "description": "Ordered list of hierarchy dimensions, broadest to narrowest.",
      "required": ["levels"],
      "additionalProperties": false,
      "properties": {
        "levels": {
          "type": "array",
          "description": "Ordered hierarchy levels, broadest first.",
          "items": { "$ref": "#/$defs/HierarchyDimension" }
        }
      }
    },
    "IssuerBetaOverride": {
      "title": "IssuerBetaOverride",
      "type": "string",
      "enum": ["auto", "force_issuer_beta", "force_bucket_only"]
    },
    "IssuerBetaPolicy": {
      "title": "IssuerBetaPolicy",
      "description": "Calibration policy governing which issuers receive a per-issuer regression.",
      "oneOf": [
        {
          "type": "object",
          "description": "Regression gated on minimum history threshold.",
          "required": ["dynamic"],
          "properties": {
            "dynamic": {
              "type": "object",
              "required": ["min_history", "overrides"],
              "additionalProperties": false,
              "properties": {
                "min_history": { "type": "integer", "minimum": 1 },
                "overrides": {
                  "type": "object",
                  "additionalProperties": { "$ref": "#/$defs/IssuerBetaOverride" }
                }
              }
            }
          }
        },
        { "const": "globally_off", "description": "Every issuer treated as BucketOnly." }
      ]
    },
    "BucketSizeThresholds": {
      "type": "object",
      "title": "BucketSizeThresholds",
      "description": "Per-level minimum-bucket-size thresholds used to gate fold-up of sparse hierarchy buckets.",
      "required": ["per_level"],
      "additionalProperties": false,
      "properties": {
        "per_level": {
          "type": "array",
          "description": "Threshold per hierarchy level. Levels beyond per_level.length use default of 5.",
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "VolModelChoice": {
      "title": "VolModelChoice",
      "description": "Volatility model selector for the per-factor variance forecast.",
      "oneOf": [
        { "const": "sample", "description": "Plain sample variance (PR-4)." },
        { "const": "garch", "description": "GARCH(1,1) — deferred to PR-5a." },
        { "const": "egarch", "description": "EGARCH — deferred to PR-5a." },
        {
          "type": "object",
          "description": "EWMA with smoothing parameter lambda — deferred to PR-5a.",
          "required": ["ewma"],
          "properties": {
            "ewma": {
              "type": "object",
              "required": ["lambda"],
              "properties": {
                "lambda": { "type": "number", "description": "Smoothing parameter." }
              }
            }
          }
        }
      ]
    },
    "CovarianceStrategy": {
      "title": "CovarianceStrategy",
      "description": "Strategy for assembling the factor covariance matrix.",
      "oneOf": [
        { "const": "diagonal", "description": "Diagonal Σ = diag(σ²) under identity correlation (PR-4 default)." },
        {
          "type": "object",
          "description": "Sample correlation plus diagonal ridge: Σ = D·ρ·D + α·I.",
          "required": ["ridge"],
          "properties": {
            "ridge": {
              "type": "object",
              "required": ["alpha"],
              "properties": {
                "alpha": { "type": "number", "minimum": 0, "description": "Ridge regularisation parameter." }
              }
            }
          }
        },
        { "const": "full_sample_repaired", "description": "Full sample covariance with PSD repair." }
      ]
    },
    "BetaShrinkage": {
      "title": "BetaShrinkage",
      "description": "OLS β shrinkage rule.",
      "oneOf": [
        { "const": "none", "description": "No shrinkage; use the OLS estimate directly." },
        {
          "type": "object",
          "description": "Convex shrinkage toward 1.0: β ← (1 - α) · β_fit + α · 1.0.",
          "required": ["toward_one"],
          "properties": {
            "toward_one": {
              "type": "object",
              "required": ["alpha"],
              "properties": {
                "alpha": { "type": "number", "minimum": 0, "maximum": 1, "description": "Shrinkage weight in [0, 1]." }
              }
            }
          }
        }
      ]
    },
    "PanelSpace": {
      "title": "PanelSpace",
      "description": "Whether the calibrator works in price-difference (return) or raw-level space.",
      "type": "string",
      "enum": ["returns", "levels"]
    }
  }
}

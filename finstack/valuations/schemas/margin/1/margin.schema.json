{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finstack.dev/schemas/margin/1/margin.schema.json",
  "title": "Finstack Margin Specification",
  "description": "OTC derivative margin specifications including CSA terms, thresholds, and collateral eligibility. Covers ISDA CSA, BCBS-IOSCO regulatory margin, and CCP clearing requirements.",
  "definitions": {
    "Money": {
      "type": "object",
      "required": ["amount", "currency"],
      "additionalProperties": false,
      "properties": {
        "amount": {
          "type": "string",
          "description": "Decimal amount as string"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code"
        }
      }
    },
    "Date": {
      "type": "string",
      "format": "date",
      "description": "ISO 8601 date (YYYY-MM-DD)"
    },
    "MarginTenor": {
      "type": "string",
      "enum": ["Daily", "Weekly", "Monthly", "OnDemand"],
      "description": "Margin call frequency. Daily is standard for OTC derivatives post-2016 under BCBS-IOSCO rules."
    },
    "ImMethodology": {
      "type": "string",
      "enum": ["Haircut", "Simm", "Schedule", "InternalModel", "ClearingHouse"],
      "description": "Initial margin calculation methodology. SIMM is the industry standard for large dealers."
    },
    "ClearingStatus": {
      "description": "Clearing status for OTC derivatives",
      "oneOf": [
        {
          "type": "string",
          "const": "Bilateral",
          "description": "Bilateral (uncleared) trade governed by CSA"
        },
        {
          "type": "object",
          "required": ["Cleared"],
          "additionalProperties": false,
          "properties": {
            "Cleared": {
              "type": "object",
              "required": ["ccp"],
              "additionalProperties": false,
              "properties": {
                "ccp": {
                  "type": "string",
                  "description": "CCP identifier (e.g., 'LCH', 'CME', 'ICE', 'JSCC')"
                }
              }
            }
          },
          "description": "Trade cleared through a central counterparty (CCP)"
        }
      ]
    },
    "MarginCallType": {
      "type": "string",
      "enum": ["InitialMargin", "VariationMarginDelivery", "VariationMarginReturn", "TopUp", "Substitution"],
      "description": "Type of margin call for proper processing and accounting treatment"
    },
    "CollateralAssetClass": {
      "type": "string",
      "description": "Collateral asset class per BCBS-IOSCO standards. Standard values: cash, government_bonds, agency_bonds, covered_bonds, corporate_bonds, equity, gold, mutual_funds. Custom values also accepted."
    },
    "MaturityConstraints": {
      "type": "object",
      "additionalProperties": false,
      "description": "Maturity constraints for eligible collateral",
      "properties": {
        "min_remaining_years": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Minimum remaining years to maturity"
        },
        "max_remaining_years": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Maximum remaining years to maturity"
        }
      }
    },
    "CollateralEligibility": {
      "type": "object",
      "required": ["asset_class", "haircut"],
      "additionalProperties": false,
      "description": "Single collateral eligibility entry with haircut",
      "properties": {
        "asset_class": {
          "$ref": "#/definitions/CollateralAssetClass",
          "description": "Asset class for this eligibility entry"
        },
        "min_rating": {
          "type": ["string", "null"],
          "description": "Minimum credit rating requirement (e.g., 'A-', 'BBB')"
        },
        "maturity_constraints": {
          "$ref": "#/definitions/MaturityConstraints"
        },
        "haircut": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Haircut as decimal (e.g., 0.02 = 2%)"
        },
        "fx_haircut_addon": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0,
          "description": "Additional FX haircut for currency mismatch (decimal). BCBS-IOSCO standard is 0.08 (8%)"
        },
        "concentration_limit": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Concentration limit as fraction of total collateral (e.g., 0.30 = max 30%)"
        }
      }
    },
    "EligibleCollateralSchedule": {
      "type": "object",
      "required": ["eligible"],
      "additionalProperties": false,
      "description": "Complete eligible collateral schedule with haircuts",
      "properties": {
        "eligible": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/CollateralEligibility"
          },
          "description": "List of eligible collateral types with haircuts"
        },
        "default_haircut": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "Default haircut for unlisted collateral (if accepted). If null, only listed types accepted."
        },
        "rehypothecation_allowed": {
          "type": "boolean",
          "default": false,
          "description": "Whether rehypothecation of posted collateral is permitted. For IM under BCBS-IOSCO, must be false."
        }
      }
    },
    "MarginCallTiming": {
      "type": "object",
      "required": ["notification_deadline_hours", "response_deadline_hours", "dispute_resolution_days", "delivery_grace_days"],
      "additionalProperties": false,
      "description": "Margin call timing parameters for operational workflows",
      "properties": {
        "notification_deadline_hours": {
          "type": "integer",
          "minimum": 0,
          "maximum": 23,
          "description": "Notification deadline (hours after valuation, e.g., 13 for 1:00 PM)"
        },
        "response_deadline_hours": {
          "type": "integer",
          "minimum": 0,
          "description": "Response deadline (hours after notification)"
        },
        "dispute_resolution_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Dispute resolution window (business days)"
        },
        "delivery_grace_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Grace period for collateral delivery (business days)"
        }
      }
    },
    "VmParameters": {
      "type": "object",
      "required": ["threshold", "mta", "rounding", "independent_amount", "frequency", "settlement_lag"],
      "additionalProperties": false,
      "description": "Variation margin parameters per ISDA CSA",
      "properties": {
        "threshold": {
          "$ref": "#/definitions/Money",
          "description": "Threshold below which no margin is exchanged. Zero for BCBS-IOSCO covered entities."
        },
        "mta": {
          "$ref": "#/definitions/Money",
          "description": "Minimum Transfer Amount. Combined IM+VM MTA must not exceed €500,000 under BCBS-IOSCO."
        },
        "rounding": {
          "$ref": "#/definitions/Money",
          "description": "Rounding increment for margin amounts"
        },
        "independent_amount": {
          "$ref": "#/definitions/Money",
          "description": "Independent Amount (IA) / Additional Margin required regardless of exposure"
        },
        "frequency": {
          "$ref": "#/definitions/MarginTenor",
          "description": "Margin call frequency"
        },
        "settlement_lag": {
          "type": "integer",
          "minimum": 0,
          "description": "Settlement lag in business days (T+n). Standard is T+1 for VM."
        }
      }
    },
    "ImParameters": {
      "type": "object",
      "required": ["methodology", "mpor_days", "threshold", "mta", "segregated"],
      "additionalProperties": false,
      "description": "Initial margin parameters per BCBS-IOSCO",
      "properties": {
        "methodology": {
          "$ref": "#/definitions/ImMethodology",
          "description": "IM calculation methodology"
        },
        "mpor_days": {
          "type": "integer",
          "minimum": 1,
          "description": "Margin Period of Risk in business days. Standard is 10 days under BCBS-IOSCO."
        },
        "threshold": {
          "$ref": "#/definitions/Money",
          "description": "IM threshold (aggregate group level). BCBS-IOSCO permits €50M."
        },
        "mta": {
          "$ref": "#/definitions/Money",
          "description": "Minimum Transfer Amount for IM"
        },
        "segregated": {
          "type": "boolean",
          "description": "Whether IM must be held in a segregated account. Required under BCBS-IOSCO."
        }
      }
    },
    "CsaSpec": {
      "type": "object",
      "required": ["id", "base_currency", "vm_params", "eligible_collateral", "call_timing", "collateral_curve_id"],
      "additionalProperties": false,
      "description": "Credit Support Annex specification (ISDA standard)",
      "properties": {
        "id": {
          "type": "string",
          "description": "CSA identifier (e.g., 'USD-CSA-STANDARD', 'COUNTERPARTY-XYZ-CSA')"
        },
        "base_currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "Base currency for margin calculations"
        },
        "vm_params": {
          "$ref": "#/definitions/VmParameters",
          "description": "Variation margin parameters"
        },
        "im_params": {
          "$ref": "#/definitions/ImParameters",
          "description": "Initial margin parameters (optional). If null, no IM is exchanged."
        },
        "eligible_collateral": {
          "$ref": "#/definitions/EligibleCollateralSchedule",
          "description": "Eligible collateral schedule with haircuts"
        },
        "call_timing": {
          "$ref": "#/definitions/MarginCallTiming",
          "description": "Margin call timing parameters"
        },
        "collateral_curve_id": {
          "type": "string",
          "description": "Discount curve ID for collateral valuation (e.g., 'USD-OIS')"
        }
      }
    },
    "OtcMarginSpec": {
      "type": "object",
      "required": ["csa", "clearing_status", "im_methodology", "vm_frequency", "settlement_lag"],
      "additionalProperties": false,
      "description": "OTC derivative margin specification (ISDA CSA compliant)",
      "properties": {
        "csa": {
          "$ref": "#/definitions/CsaSpec",
          "description": "Full CSA specification"
        },
        "clearing_status": {
          "$ref": "#/definitions/ClearingStatus",
          "description": "Clearing status: bilateral or cleared through CCP"
        },
        "im_methodology": {
          "$ref": "#/definitions/ImMethodology",
          "description": "Initial margin calculation methodology"
        },
        "vm_frequency": {
          "$ref": "#/definitions/MarginTenor",
          "description": "Variation margin exchange frequency"
        },
        "settlement_lag": {
          "type": "integer",
          "minimum": 0,
          "description": "Settlement lag for margin transfers (business days)"
        }
      }
    },
    "MarginCall": {
      "type": "object",
      "required": ["call_date", "settlement_date", "call_type", "amount", "mtm_trigger", "threshold", "mta_applied"],
      "additionalProperties": false,
      "description": "Margin call event with all relevant details for processing",
      "properties": {
        "call_date": {
          "$ref": "#/definitions/Date",
          "description": "Date the margin call is issued"
        },
        "settlement_date": {
          "$ref": "#/definitions/Date",
          "description": "Settlement date for the margin transfer"
        },
        "call_type": {
          "$ref": "#/definitions/MarginCallType",
          "description": "Type of margin call"
        },
        "amount": {
          "$ref": "#/definitions/Money",
          "description": "Amount of margin required (positive = delivery, negative = return)"
        },
        "collateral_type": {
          "$ref": "#/definitions/CollateralAssetClass",
          "description": "Specific collateral type requested (optional)"
        },
        "mtm_trigger": {
          "$ref": "#/definitions/Money",
          "description": "Mark-to-market value that triggered the call"
        },
        "threshold": {
          "$ref": "#/definitions/Money",
          "description": "Threshold in effect at time of call"
        },
        "mta_applied": {
          "$ref": "#/definitions/Money",
          "description": "MTA applied (may have reduced the call amount)"
        }
      }
    }
  },
  "oneOf": [
    {
      "type": "object",
      "required": ["schema", "otc_margin_spec"],
      "additionalProperties": false,
      "properties": {
        "schema": {
          "type": "string",
          "const": "finstack.margin/1",
          "description": "Schema version identifier"
        },
        "otc_margin_spec": {
          "$ref": "#/definitions/OtcMarginSpec"
        }
      }
    },
    {
      "type": "object",
      "required": ["schema", "csa_spec"],
      "additionalProperties": false,
      "properties": {
        "schema": {
          "type": "string",
          "const": "finstack.margin/1",
          "description": "Schema version identifier"
        },
        "csa_spec": {
          "$ref": "#/definitions/CsaSpec"
        }
      }
    },
    {
      "type": "object",
      "required": ["schema", "margin_call"],
      "additionalProperties": false,
      "properties": {
        "schema": {
          "type": "string",
          "const": "finstack.margin/1",
          "description": "Schema version identifier"
        },
        "margin_call": {
          "$ref": "#/definitions/MarginCall"
        }
      }
    }
  ]
}

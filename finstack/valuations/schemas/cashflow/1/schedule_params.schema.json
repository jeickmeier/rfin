{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finstack.dev/schemas/cashflow/1/schedule_params.schema.json",
  "title": "Schedule Parameters",
  "description": "Schedule parameter types for cashflow generation. Rust type: ScheduleParams from finstack_valuations::cashflow::builder::specs::schedule",
  "definitions": {
    "Frequency": {
      "description": "Payment or reset frequency",
      "oneOf": [
        {
          "type": "object",
          "required": ["Months"],
          "additionalProperties": false,
          "properties": {
            "Months": {
              "type": "integer",
              "minimum": 1,
              "description": "Period in months (e.g., 3 for quarterly, 6 for semi-annual, 12 for annual)"
            }
          }
        }
      ]
    },
    "DayCount": {
      "type": "string",
      "enum": ["Act360", "Act365F", "ActAct", "Thirty360"],
      "description": "Day count convention"
    },
    "BusinessDayConvention": {
      "type": "string",
      "enum": ["unadjusted", "following", "modified_following", "preceding", "modified_preceding"],
      "description": "Business day adjustment convention"
    },
    "StubKind": {
      "type": "string",
      "enum": ["None", "ShortFront", "ShortBack", "LongFront", "LongBack"],
      "description": "Stub period handling"
    },
    "ScheduleParams": {
      "type": "object",
      "required": ["freq", "dc", "bdc", "stub"],
      "additionalProperties": false,
      "description": "Schedule parameters for cashflow generation",
      "properties": {
        "freq": {
          "$ref": "#/definitions/Frequency",
          "description": "Payment frequency"
        },
        "dc": {
          "$ref": "#/definitions/DayCount",
          "description": "Day count convention"
        },
        "bdc": {
          "$ref": "#/definitions/BusinessDayConvention",
          "description": "Business day convention"
        },
        "calendar_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional calendar identifier"
        },
        "stub": {
          "$ref": "#/definitions/StubKind",
          "description": "Stub period handling"
        }
      }
    }
  },
  "type": "object",
  "required": ["schema", "schedule_params"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "finstack.cashflow/1",
      "description": "Schema version identifier"
    },
    "schedule_params": {
      "$ref": "#/definitions/ScheduleParams"
    }
  }
}

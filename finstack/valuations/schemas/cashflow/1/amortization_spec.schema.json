    "Money": {
      "additionalProperties": false,
      "description": "Currency-tagged monetary amount with safe arithmetic.\n\nValues are stored using a fixed-point representation derived from ISO 4217\ndecimal places.\n\nWhen you need configurable rounding during ingestion, use\n[`Money::new_with_config`].\n\n# Examples\n```rust\nuse finstack_core::money::Money;\nuse finstack_core::currency::Currency;\n\nlet notional = Money::new(1_000_000.0, Currency::EUR);\nassert_eq!(notional.currency(), Currency::EUR);\nassert_eq!(notional.amount(), 1_000_000.0);\n```",
      "properties": {
        "amount": {
          "pattern": "^-?\\d+(\\.\\d+)?([eE]\\d+)?$",
          "type": [
            "string",
            "number"
          ]
        },
        "currency": {
          "$ref": "#/$defs/Currency"
        }
      },
      "required": [
        "amount",
        "currency"
      ],
      "type": "object"
    }
  },
  "$id": "https://finstack.dev/schemas/cashflow/1/amortization_spec.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Amortization and notional specifications for cashflow principal schedules. Rust types: AmortizationSpec, Notional from finstack_valuations::cashflow::builder::specs::amortization",
  "oneOf": [
    {
      "const": "None",
      "description": "No amortization – principal remains constant until final redemption.",
      "type": "string"
    },
    {
      "additionalProperties": false,
      "description": "Linear principal paydown towards a target final notional amount over all periods.",
      "properties": {
        "LinearTo": {
          "properties": {
            "final_notional": {
              "$ref": "#/$defs/Money",
              "description": "Target remaining principal at the end of the amortization schedule."
            }
          },
          "required": [
            "final_notional"
          ],
          "type": "object"
        }
      },
      "required": [
        "LinearTo"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "description": "Explicit schedule of remaining principal amounts after given dates.\nEach pair stores `(date, remaining_principal_after_date)`.",
      "properties": {
        "StepRemaining": {
          "properties": {
            "schedule": {
              "description": "Ordered list of `(date, remaining_principal_after_date)`.",
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "$ref": "#/$defs/Money"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            }
          },
          "required": [
            "schedule"
          ],
          "type": "object"
        }
      },
      "required": [
        "StepRemaining"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "description": "Fixed percentage of **original** notional paid each period (capped by remaining outstanding).\n\nThis is a sinking-fund style amortization where the payment amount is constant\nacross periods: `initial_notional * pct`. It does **not** compound (i.e., it is\nNOT percentage-of-remaining / declining-balance / mortgage-style).",
      "properties": {
        "PercentOfOriginalPerPeriod": {
          "properties": {
            "pct": {
              "description": "Fraction of original notional paid per period (e.g., 0.05 = 5%).",
              "format": "double",
              "type": "number"
            }
          },
          "required": [
            "pct"
          ],
          "type": "object"
        }
      },
      "required": [
        "PercentOfOriginalPerPeriod"
      ],
      "type": "object"
    },
    {
      "additionalProperties": false,
      "description": "Custom principal exchanges on specific dates (absolute cash amounts).\nPositive amounts reduce outstanding (i.e., principal paid by issuer).",
      "properties": {
        "CustomPrincipal": {
          "properties": {
            "items": {
              "description": "List of `(date, principal_amount)` exchanges; amounts are absolute cashflows.",
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "$ref": "#/$defs/Money"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            }
          },
          "required": [
            "items"
          ],
          "type": "object"
        }
      },
      "required": [
        "CustomPrincipal"
      ],
      "type": "object"
    }
  ],
  "title": "Amortization Specification"
}

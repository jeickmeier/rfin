{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finstack.dev/schemas/cashflow/1/prepayment_model_spec.schema.json",
  "title": "Prepayment Model Specification",
  "description": "Prepayment model specifications for credit instruments. Rust types: PrepaymentCurve, PrepaymentModelSpec from finstack_valuations::cashflow::builder::specs::prepayment",
  "definitions": {
    "PrepaymentCurve": {
      "description": "Prepayment curve shape",
      "type": "object",
      "required": ["curve"],
      "oneOf": [
        {
          "properties": {
            "curve": {
              "type": "string",
              "const": "constant"
            }
          },
          "additionalProperties": false,
          "description": "Constant CPR (no seasoning effect)"
        },
        {
          "properties": {
            "curve": {
              "type": "string",
              "const": "psa"
            },
            "speed_multiplier": {
              "type": "number",
              "description": "Speed multiplier (1.0 = 100% PSA)"
            }
          },
          "required": ["curve", "speed_multiplier"],
          "additionalProperties": false,
          "description": "PSA standard curve: ramps to 6% CPR over 30 months"
        }
      ]
    },
    "PrepaymentModelSpec": {
      "type": "object",
      "required": ["cpr"],
      "additionalProperties": false,
      "description": "Prepayment model specification",
      "properties": {
        "cpr": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "CPR: Constant Prepayment Rate (annual, e.g., 0.06 for 6%)"
        },
        "curve": {
          "anyOf": [
            {
              "$ref": "#/definitions/PrepaymentCurve"
            },
            {
              "type": "null"
            }
          ],
          "description": "Optional curve shape (default: constant)"
        }
      }
    }
  },
  "type": "object",
  "required": ["schema", "prepayment_model_spec"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "finstack.cashflow/1",
      "description": "Schema version identifier"
    },
    "prepayment_model_spec": {
      "$ref": "#/definitions/PrepaymentModelSpec"
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finstack.dev/schemas/cashflow/1/recovery_model_spec.schema.json",
  "title": "Recovery Model Specification",
  "description": "Recovery model specifications for credit instruments. Rust type: RecoveryModelSpec from finstack_valuations::cashflow::builder::specs::recovery",
  "definitions": {
    "RecoveryModelSpec": {
      "type": "object",
      "required": ["rate", "recovery_lag"],
      "additionalProperties": false,
      "description": "Recovery model specification",
      "properties": {
        "rate": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Recovery rate as fraction (0.0 to 1.0, e.g., 0.40 for 40%)"
        },
        "recovery_lag": {
          "type": "integer",
          "minimum": 0,
          "description": "Recovery lag in months"
        }
      }
    }
  },
  "type": "object",
  "required": ["schema", "recovery_model_spec"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "finstack.cashflow/1",
      "description": "Schema version identifier"
    },
    "recovery_model_spec": {
      "$ref": "#/definitions/RecoveryModelSpec"
    }
  }
}

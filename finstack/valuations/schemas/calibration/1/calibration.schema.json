{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finstack.io/schemas/calibration/1/calibration.schema.json",
  "title": "Finstack Calibration Specification",
  "description": "Complete specification for market data calibration runs using explicit pipeline mode",
  "type": "object",
  "required": ["schema", "calibration"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "finstack.calibration/1",
      "description": "Schema version identifier"
    },
    "calibration": {
      "type": "object",
      "description": "The calibration specification",
      "required": ["base_date", "base_currency", "config", "steps"],
      "additionalProperties": false,
      "properties": {
        "base_date": {
          "type": "string",
          "format": "date",
          "description": "Base date for all calibrations (YYYY-MM-DD)"
        },
        "base_currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$",
          "description": "ISO 4217 currency code"
        },
        "config": {
          "$ref": "config.schema.json#/definitions/CalibrationConfig",
          "description": "Global calibration configuration (can be overridden per step)"
        },
        "steps": {
          "type": "array",
          "items": { "$ref": "calibration_step.schema.json#/definitions/CalibrationStep" },
          "description": "Ordered calibration steps"
        },
        "schema_version": {
          "type": "integer",
          "default": 1,
          "description": "Schema version number"
        }
      }
    }
  }
}

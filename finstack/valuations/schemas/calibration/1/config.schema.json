{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finstack.io/schemas/calibration/1/config.schema.json",
  "title": "Calibration Configuration",
  "description": "Configuration for calibration solver and validation settings",
  "definitions": {
    "CalibrationConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tolerance": { "type": "number", "default": 1e-10 },
        "max_iterations": { "type": "integer", "default": 100 },
        "use_parallel": { "type": "boolean", "default": false },
        "random_seed": { "type": ["integer", "null"], "default": 42 },
        "verbose": { "type": "boolean", "default": false },
        "solver_kind": {
          "type": "string",
          "enum": ["Newton", "Brent", "Hybrid", "LevenbergMarquardt", "DifferentialEvolution"],
          "default": "Hybrid"
        },
        "entity_seniority": {
          "type": "object",
          "additionalProperties": { "type": "string", "enum": ["senior_secured", "senior", "subordinated", "junior"] }
        },
        "multi_curve": {
          "type": "object",
          "properties": {
            "calibrate_basis": { "type": "boolean", "default": true },
            "enforce_separation": { "type": "boolean", "default": true }
          }
        },
        "use_fd_sabr_gradients": { "type": "boolean", "default": false },
        "validation_mode": {
          "type": "string",
          "enum": ["Warn", "Error"],
          "default": "Warn"
        }
      }
    }
  }
}


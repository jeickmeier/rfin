//! Unit tests for core valuations traits.
//!
//! This module tests the fundamental trait contracts that all instruments implement:
//! - `CashflowProvider`: Generating and discounting cashflow schedules
//! - `Priceable`: Valuation and metrics computation
//!
//! These tests use simple mock implementations to validate trait behavior in isolation,
//! separate from the comprehensive instrument-by-instrument integration tests.

use finstack_core::math::interp::InterpStyle;
use finstack_core::{
    currency::Currency,
    dates::{Date, DayCount},
    market_data::{term_structures::discount_curve::DiscountCurve, MarketContext},
    money::Money,
    // F,
};
use finstack_valuations::{
    cashflow::traits::{CashflowProvider, DatedFlows},
    // Priceable trait removed,
    metrics::MetricId,
    results::ValuationResult,
};
use hashbrown::HashMap;

// Dummy cashflow provider for testing
#[derive(Debug, Clone)]
struct TestCashflowProvider {
    flows: DatedFlows,
}

impl TestCashflowProvider {
    fn new(flows: DatedFlows) -> Self {
        Self { flows }
    }
}

impl CashflowProvider for TestCashflowProvider {
    fn build_schedule(
        &self,
        _curves: &MarketContext,
        _as_of: Date,
    ) -> finstack_core::Result<DatedFlows> {
        Ok(self.flows.clone())
    }
}

// Dummy priceable instrument for testing
#[derive(Debug, Clone)]
struct TestPriceable {
    value: Money,
}

impl TestPriceable {
    fn new(value: Money) -> Self {
        Self { value }
    }
}


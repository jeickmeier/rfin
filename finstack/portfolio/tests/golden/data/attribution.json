        }
      },
      "expected": {
        "rates_pnl_direction": {
          "min": null,
          "max": 0.0,
          "notes": "Positive rate shock -> negative P&L for long bond"
        },
        "rates_pnl_magnitude": {
          "min": -100000.0,
          "max": 0.0,
          "notes": "Reasonable magnitude for 5Y bond with ~4.5 duration on 1M notional with 100bp shock"
        }
      }
    },

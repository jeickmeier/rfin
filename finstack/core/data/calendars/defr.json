{
  "id": "defr",
  "name": "Germany (Frankfurt) Holiday Calendar",
  "ignore_weekends": false,
  "rules": [
    { "type": "fixed", "name": "Neujahr (New Year's Day)", "month": "january", "day": 1, "observed": "next_monday" },
    { "type": "easter_offset", "name": "Karfreitag (Good Friday)", "days": -3 },
    { "type": "easter_offset", "name": "Ostermontag (Easter Monday)", "days": 0 },
    { "type": "fixed", "name": "Tag der Arbeit (Labour Day)", "month": "may", "day": 1, "observed": "next_monday" },
    { "type": "fixed", "name": "Erster Weihnachtstag (Christmas Day)", "month": "december", "day": 25, "observed": "next_monday" },
    { "type": "fixed", "name": "Zweiter Weihnachtstag (St. Stephen's Day)", "month": "december", "day": 26, "observed": "next_monday" }
  ]
}

{
  "id": "auce",
  "name": "Australia (Commonwealth) Holiday Calendar",
  "ignore_weekends": false,
  "rules": [
    { "type": "fixed", "name": "New Year's Day", "month": "january", "day": 1, "observed": "next_monday" },
    { "type": "weekday_shift", "name": "Australia Day", "weekday": "monday", "month": "january", "day": 26, "dir": "after" },
    { "type": "easter_offset", "name": "Good Friday", "days": -3 },
    { "type": "easter_offset", "name": "Easter Monday", "days": 0 },
    { "type": "fixed", "name": "ANZAC Day", "month": "april", "day": 25 },
    { "type": "nth_weekday", "name": "King's Birthday", "n": 2, "weekday": "monday", "month": "june" },
    { "type": "nth_weekday", "name": "Bank Holiday", "n": 1, "weekday": "monday", "month": "august" },
    { "type": "nth_weekday", "name": "Labour Day", "n": 1, "weekday": "monday", "month": "october" },
    { "type": "fixed", "name": "Christmas Day", "month": "december", "day": 25, "observed": "next_monday" },
    { "type": "fixed", "name": "Boxing Day", "month": "december", "day": 26, "observed": "next_monday" }
  ]
}

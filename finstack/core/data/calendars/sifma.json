{
  "id": "sifma",
  "name": "SIFMA U.S. Bond Market Holidays",
  "ignore_weekends": false,
  "rules": [
    { "type": "fixed_weekend", "name": "New Year's Day", "month": "january", "day": 1 },
    { "type": "fixed_weekend", "name": "Juneteenth National Independence Day", "month": "june", "day": 19 },
    { "type": "fixed_weekend", "name": "Independence Day", "month": "july", "day": 4 },
    { "type": "fixed_weekend", "name": "Christmas Day", "month": "december", "day": 25 },
    { "type": "nth_weekday", "name": "Martin Luther King Jr. Day", "n": 3, "weekday": "monday", "month": "january" },
    { "type": "nth_weekday", "name": "Washington's Birthday", "n": 3, "weekday": "monday", "month": "february" },
    { "type": "nth_weekday", "name": "Memorial Day", "n": -1, "weekday": "monday", "month": "may" },
    { "type": "nth_weekday", "name": "Labor Day", "n": 1, "weekday": "monday", "month": "september" },
    { "type": "nth_weekday", "name": "Thanksgiving Day", "n": 4, "weekday": "thursday", "month": "november" },
    { "type": "easter_offset", "name": "Good Friday", "days": -3 },
    { "type": "nth_weekday", "name": "Columbus Day", "n": 2, "weekday": "monday", "month": "october" },
    { "type": "fixed_weekend", "name": "Veterans Day", "month": "november", "day": 11 }
  ]
}



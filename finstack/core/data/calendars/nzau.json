{
  "id": "nzau",
  "name": "New Zealand (Auckland) Holiday Calendar",
  "ignore_weekends": false,
  "rules": [
    { "type": "fixed", "name": "New Year's Day", "month": "january", "day": 1, "observed": "next_monday" },
    { "type": "fixed", "name": "Day after New Year's Day", "month": "january", "day": 2, "observed": "next_monday" },
    { "type": "fixed", "name": "Waitangi Day", "month": "february", "day": 6, "observed": "next_monday" },
    { "type": "easter_offset", "name": "Good Friday", "days": -3 },
    { "type": "easter_offset", "name": "Easter Monday", "days": 0 },
    { "type": "fixed", "name": "ANZAC Day", "month": "april", "day": 25, "observed": "next_monday" },
    { "type": "nth_weekday", "name": "King's Birthday", "n": 1, "weekday": "monday", "month": "june" },
    { "type": "nth_weekday", "name": "Labour Day", "n": 4, "weekday": "monday", "month": "october" },
    { "type": "fixed", "name": "Christmas Day", "month": "december", "day": 25, "observed": "next_monday" },
    { "type": "fixed", "name": "Boxing Day", "month": "december", "day": 26, "observed": "next_monday" }
  ]
}



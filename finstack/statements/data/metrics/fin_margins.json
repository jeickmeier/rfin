{
  "namespace": "fin",
  "schema_version": 1,
  "metrics": [
    {
      "id": "gross_margin",
      "name": "Gross Margin %",
      "formula": "gross_profit / revenue",
      "description": "Gross profit as percentage of revenue",
      "category": "margins",
      "unit_type": "percentage",
      "requires": ["revenue", "gross_profit"],
      "tags": ["margins", "profitability"]
    },
    {

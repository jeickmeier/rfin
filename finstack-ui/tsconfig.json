{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "baseUrl": "src",
    "paths": {
      "@finstack-ui/components/*": ["components/*"],
      "@finstack-ui/hooks/*": ["hooks/*"],
      "@finstack-ui/utils/*": ["utils/*"],
      "@finstack-ui/workers/*": ["workers/*"],
      "@finstack-ui/types/*": ["types/*"],
      "@finstack-ui/lib/*": ["lib/*"],
      "@finstack-ui/store/*": ["store/*"],
      "@/components/*": ["components/*"],
      "@/hooks/*": ["hooks/*"],
      "@/utils/*": ["utils/*"],
      "@/workers/*": ["workers/*"],
      "@/types/*": ["types/*"],
      "@/lib/*": ["lib/*"],
      "@/store/*": ["store/*"]
    },
    "types": ["vitest/globals", "@testing-library/jest-dom"]
  },
  "include": [
    "src",
    "tests",
    "vite.config.ts",
    "vitest.setup.ts",
    "tailwind.config.cjs"
  ],
  "exclude": ["dist", "node_modules"]
}
